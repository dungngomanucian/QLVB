

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@Html.Raw(RICTotal.Models.common.app_title)</title>
    <meta content="@Html.Raw(RICTotal.Models.common.app_keywords)" name="keywords">
    <meta content="@Html.Raw(RICTotal.Models.common.app_description)" name="description">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">

    <meta property="og:title" content="Nhà xuất bản đại học Sư Phạm" />

    <meta property="og:url" content="@ViewBag.Url_address" />
    <meta property="og:image" itemprop="thumbnailUrl" content="@ViewBag.Url" />
    <meta property="og:image:width" content="400" />
    <meta property="og:image:height" content="300" />
    <meta property="og:site_name" content="CPA VietNam" />
    <meta property="og:description" content="@ViewBag.Description" />


    <link rel="shortcut icon" href="/favicon.ico">
    <link href="~/Styles/googlefont.css" rel="stylesheet" />

   

    <link rel="stylesheet" href="~/Styles/bootstrap/bootstrap.min.css">
    <link rel="stylesheet" href="~/Styles/font-awesome/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/Styles/Ionicons/css/ionicons.min.css">
    <link rel="stylesheet" href="~/Styles/skin.css">
    <link rel="stylesheet" href="~/Styles/common.css">
    <link rel="stylesheet" href="~/Styles/bill.css">


    <link href="~/kendoui/styles/kendo.common.min.css" rel="stylesheet">
    <link href="~/kendoui/styles/kendo.default.min.css" rel="stylesheet">
    <link href="~/kendoui/styles/kendo.default.mobile.min.css" rel="stylesheet">
    <script src="~/js/jquery.min.js"></script>
    <!--
    <script src="~/Scripts/jquery.min.js"></script>
    -->
    <script src="~/Scripts/jquery-ui.min.js"></script>
    <!--
    <script src="~/Scripts/bootstrap.min.js"></script>
    -->
    <script src="~/Scripts/jquery.slimscroll.min.js"></script>
    <script src="~/Scripts/lib/admin.min.js"></script>
    <script src="~/Scripts/angular.min.js"></script>
    <script src="~/Scripts/angular-sanitize.js"></script>
    <script>
    @Html.Raw(File.ReadAllText(Server.MapPath("~/Scripts/common.js")))
    @Html.Raw(File.ReadAllText(Server.MapPath("~/App/mrictotal.js")))

    </script>


    <script src="~/kendoui/js/kendo.all.min.js"></script>


    <link rel="stylesheet" type="text/css" href="~/Marquee/examples.css" />



    <link href="~/Notification/toastr.css" rel="stylesheet" />


    <script src="~/Notification/toastr.js"></script>
    <script src="~/Notification/script.js"></script>
    <!--Tao menu dropdown-->
    <link rel="stylesheet" type="text/css" href="/js/menu/default.css" />
    <link rel="stylesheet" type="text/css" href="/js/menu/component.css" />
    <script src="/js/menu/modernizr.custom.js"></script>



</head>

<body style="margin-left:0px; margin-top:0px" ng-app="mtmain">

    <!--Banner Top-->
    <div class="section" style="background-color:#ffffff;">
        <div class="container" style="text-align:center">
            <div class="row">
                <img src="~/img/bannerTop.jpg" class="img-responsive" />
            </div>

        </div>
    </div>
    <!--End of BannerTop-->
    <!-- Menu Top-->
    <div class="section" style="background-color:#ffffff;  ">
        <div class="container" style="background-color:#DC8D0A; ">
            <div class="row">

                @Html.Partial("_header")

            </div>

        </div>
    </div>
    <!-- End of MenuTop-->
    <!-- Hot news scroll-->
    <div class="section" style="background-color:#ffffff;  ">
        <div class="container" style="padding-top:5px;padding-bottom:5px;background-color:#247E0C;border-top:1px solid #ffffff ">
            <div class="row">
                <div class="col-lg-1 col-md-1 col-xs-3" style="padding:0px; margin:0px">
                    <img class="img-hot-new" src="@ViewBag.New_Title_Hot" />
                </div>
                <div class="col-lg-11 col-md-11 col-xs-9" style="margin-top:5px;margin-right:0px; padding-right:0px">
                    <div class="promo-carousel" id="grouploop-1">
                        <div class="itemMarquee-wrap">

                            @{
                                for (int i = 0; i < ViewBag.HotNew.Rows.Count; i++)
                                {
                                    string hotnew1 = RICTotal.Models.common._createURLFromText(@ViewBag.HotNew.Rows[i]["CA_Title"].ToString());
                                    hotnew1 = @ViewBag.HotNew.Rows[i]["CA_Identify"].ToString() + "-" + hotnew1;
                                    <div class="itemMarquee active" style="width:250px;max-width:250px;">
                                        <a href="/ContentArticlesDetails/@hotnew1"> @ViewBag.HotNew.Rows[i]["CC_Name"].ToString()</a>
                                    </div>
                                    <div class="itemMarquee">
                                        <a href="/ContentArticlesDetails/@hotnew1"> @ViewBag.HotNew.Rows[i]["CA_Title"].ToString()</a>

                                    </div>

                                }
                            }

                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>
    <!-- End of Hot news scroll-->
    <div id="navigation" style="background-color:#ffffff;">
        <div class="container">
            <div class="row">
                @Html.Partial("_breadcrumb")
            </div>

        </div>
    </div>
    <!--Noi dung chinh trang-->
    <div class="section" style="background-color:#ffffff;  ">
        <div class="container" style="background-color:#F4F3F8; ">
            <div class="row">
                <div class="col-lg-3 col-md-3 col-xs-6">
                    <div class="row">
                        @Html.Partial("_menu_left")
                    </div>
                    <div class="row" style="height:10px"></div>
                    <!--Tao lien ket website-->
                  

                    <div class="row head1Bold" >
                        @ViewBag.weblink
                    </div>
                    <div class="row" style="height:10px"></div>
                    <div class="row">
                        <section class="vertical slider">
                            @{for (int j = 0; j < ViewBag.WeblinkInfo.Rows.Count; j++)
                                {
                                    <div style="padding-bottom:10px; margin-left:0px; ">
                                        <img style="width:95%" class="img-responsive" src="@ViewBag.WeblinkInfo.Rows[j]["WL_Image"].ToString()" alt="">

                                    </div>
                                }
                            }
                        </section>
                    </div>
                    <!--End of lien ket website-->
                    <!--Thong tin VIsitor-->
                    <div class="row head1Bold" id="responsive-nav" style="padding-top:30px;padding-bottom:10px">
                        @ViewBag.Visitor
                    </div>
                    <div class="row">

                        <div style="background-color:#3B3C58; width:90%; height:125px;border:solid 1px #626379;padding:10px;  ">
                            <div style="text-align:center; margin-top:10px;margin-bottom:10px;">
                                <table border="0" cellpadding="5" cellspacing="0" width="90%" align="center">
                                    <tr>
                                        <td><img src="~/img/counter/0.gif" id="visitorImg1" style="width:20px" /></td>
                                        <td><img src="~/img/counter/0.gif" id="visitorImg2" style="width:20px" /></td>
                                        <td><img src="~/img/counter/0.gif" id="visitorImg3" style="width:20px" /></td>
                                        <td><img src="~/img/counter/0.gif" id="visitorImg4" style="width:20px" /></td>
                                        <td><img src="~/img/counter/0.gif" id="visitorImg5" style="width:20px" /></td>
                                        <td><img src="~/img/counter/0.gif" id="visitorImg6" style="width:20px" /></td>
                                        <td><img src="~/img/counter/0.gif" id="visitorImg7" style="width:20px" /></td>
                                        <td><img src="~/img/counter/0.gif" id="visitorImg8" style="width:20px" /></td>


                                    </tr>
                                </table>

                            </div>

                            <div class="TitleVisitor"><img src="~/img/counter/mvcvisit.png" style="width:16px" />&nbsp;Visit Today: @HttpContext.Current.Application["visitors_online"].ToString()</div>
                            <div class="TitleVisitor"><img src="~/img/counter/mvctotal.png" style="width:16px" />&nbsp;Total Visit: @HttpContext.Current.Application["TatCa"].ToString()</div>
                        </div>
                    </div>
                    <!--End of Visitor-->
                </div>
                <div class="col-lg-9 col-md-9 col-xs-6">
                    <div class="row">
                        @RenderBody()
                    </div>

                </div>

            </div>
        </div>
    </div>
    <!--End of noi dung-->
    <!--Tạo hang trong-->
    <!--End Tạo hang trong-->
    <!--Begin of Address-->
    <!--End of Address-->
    <!--Footer-->
    <div class="row" style="height:2px;"></div>
    <div class="section" style="background-color:#ffffff;  ">
        <div class="container" style="background-color:#67CB35; ">
            <div class="row">

                <div class="address">@Html.Raw(ViewBag.Address.Rows[0]["Add_ContentBody"].ToString())</div>
            </div>
        </div>
    </div>
    <!--End of Footer-->

    <script src="~/slick/slick.js" type="text/javascript" charset="utf-8"></script>


    <script type="text/javascript" src="~/Marquee/grouploop-1.0.0.min.js"></script>
    <script>
            $('#grouploop-1').grouploop({
                velocity: 1,
                forward: false,
                pauseOnHover: true,
                childNode: ".itemMarquee",
                childWrapper: ".itemMarquee-wrap",
                complete: function () { console.log("Initialized a grouploop with id: " + $(this).attr('id')) }
            });

    </script>
    <script type="text/javascript">
            $(document).on('ready', function () {
                $(".vertical-center-4").slick({
                    dots: true,
                    vertical: true,
                    centerMode: true,
                    slidesToShow: 6,
                    slidesToScroll: 2,
                    autoplay: true,
                });
                $(".vertical-center-3").slick({
                    dots: true,
                    vertical: true,
                    centerMode: true,
                    slidesToShow: 3,
                    slidesToScroll: 3
                });
                $(".vertical-center-2").slick({
                    dots: true,
                    vertical: true,
                    centerMode: true,
                    slidesToShow: 2,
                    slidesToScroll: 2
                });
                $(".vertical-center").slick({
                    dots: true,
                    vertical: true,
                    centerMode: true,
                });
                $(".vertical").slick({
                    dots: false,
                    vertical: true,
                    slidesToShow: 3,
                    slidesToScroll: 1,
                    autoplay: true,

                    speed: 3500,
                    autoplaySpeed: 0,
                    centerMode: true,
                    cssEase: 'linear',

                    infinite: true,
                    initialSlide: 1,
                    arrows: false,
                    buttons: false
                });
                $(".regular").slick({
                    dots: false,
                    infinite: true,
                    slidesToShow: 4,
                    slidesToScroll: 4,
                    autoplay: true,
                    nextArrow: '',
                    prevArrow: '',

                });


                $(".center").slick({
                    dots: true,
                    infinite: true,
                    centerMode: true,
                    slidesToShow: 5,
                    slidesToScroll: 3
                });
                $(".variable").slick({
                    speed: 7000,
                    autoplay: true,
                    autoplaySpeed: 0,
                    centerMode: true,
                    cssEase: 'linear',
                    slidesToShow: 4,
                    slidesToScroll: 1,

                    infinite: true,
                    initialSlide: 1,
                    arrows: false,
                    buttons: false,
                    focusOnSelect: true,
                    pauseOnHover: true,
                });
                $(".lazy").slick({
                    lazyLoad: 'ondemand', // ondemand progressive anticipated

                    dots: false,
                    infinite: true,
                    autoplay: true,
                    autoplay: true,
                    nextArrow: '',
                    prevArrow: '',
                    autoplaySpeed:10000,

                });
            });
    </script>

    <!--Xu ly thong tin bo dem Visitor-->
    <script>
    $(document).ready(function () {

        var total=parseInt( @HttpContext.Current.Application["TatCa"]);
        var du;
        var arrImage = ["/img/counter/1.gif", "", "", "", "", "", "", "", ""];
        var strImage = "visitorImg";
        var k = 8;
        while (total != 0)
        {
            strImage = "visitorImg";
            du = total % 10;
            total = parseInt(total / 10);
            strImage = strImage + k;
            k--;
            var img1 = document.getElementById(strImage);
            var anh = "/img/counter/" + du + ".gif";
            img1.src = anh;
        }

    });

    </script>
</body>

</html>

<script src="~/js/talk.js"></script>
<script src="~/js/bootstrap.min.js"></script>
<script src="~/js/slick.min.js"></script>
<script src="~/js/nouislider.min.js"></script>
<script src="~/js/jquery.zoom.min.js"></script>
<script src="~/js/main.js"></script>
