 

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Html.Raw(RICTotal.Models.common.app_title)</title>
    <meta content="@Html.Raw(RICTotal.Models.common.app_keywords)" name="keywords" />
    <meta content="@Html.Raw(RICTotal.Models.common.app_description)" name="description" />
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport" />

    <meta property="og:title" content="Công ty TNHH Kiểm toán CPA VIETNAM" />

    <meta property="og:url" content="@ViewBag.Url_address" />
    <meta property="og:image" itemprop="thumbnailUrl" content="@ViewBag.Url" />
    <meta property="og:image:width" content="400" />
    <meta property="og:image:height" content="300" />
    <meta property="og:site_name" content="CPA VietNam" />
    <meta property="og:description" content="@ViewBag.Description" />



    <link rel="stylesheet" type="text/css" href="~/Marquee/examples.css" />
    <link rel="stylesheet" type="text/css" href="~/Styles/skin.css" />
    <script src="~/Scripts/jQueryCaruel/jquery.min.js"></script>


    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/jquery-ui.min.js"></script>

    <script src="~/Scripts/angular.min.js"></script>
    <script src="~/Scripts/angular-sanitize.js"></script>

    <!--THong tin cho soan thao van ban -->
    <script src="~/Content/ckeditor/ckeditor.js" type="text/javascript"></script>
    <script src="~/Content/ckfinder/ckfinder.js" type="text/javascript"></script>
    <script src="~/kendoui/js/kendo.all.min.js"></script>
</head>


<body style="margin-left:0px; margin-top:0px" ng-app="mtmain">
    <script>
     @Html.Raw(File.ReadAllText(Server.MapPath("~/Scripts/common.js")))
     @Html.Raw(File.ReadAllText(Server.MapPath("~/App/mrictotal.js")))
    </script>
    <!--Thong tin top-->
    <div class="section" style="background-color:#ffffff;  ">
        <div class="row VerticalAlignStyle1" style="padding:0px; margin:0">
            <div class="col-lg-9 col-xs-12">
                <div class="row">
                    <div class="hidden-xs outer">
                        <div class="inner">
                            <a href="https://www.facebook.com/nxbdhsp.edu.vn" target="_blank">
                                <i class="fa fa-facebook-square"></i>
                            </a>
                        </div>
                    </div>
                    <div class="outer">
                        <div class="inner">
                            024 3754 7735 <span class="fusion-header-separator">|</span> Fax : 024 3754 7911<span class="fusion-header-separator">&nbsp; |&nbsp; </span>
                            <span>
                                <a class="info" href="mailto: hanhchinh.nxb@hnue.edu.vn"> atc@samsung.com</a>

                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="hidden-xs col-lg-3 col-xs-12">
                <div class="row">
                    @Html.Partial("menu_top")
                </div>
            </div>
        </div>
    </div>
    <!--End of top-->
    <!--Begin of information of Head-->
    <div class="section" style="background-color:#01A14B; border-top:2px solid #ffffff;">
        <div class="row topnav" style="padding:0; margin:0">
            <div style="float:left">
                @Html.Partial("_header")
            </div>
            <div class="search-container">
                <input type="text" id="txtcontentsearch" placeholder="Search.." name="search">
                <button type="submit" id="cmdSearch"><i class="fa fa-search"></i></button>
            </div>
        </div>
    </div>
    <!--End of menu head-->
    <!--Begin of content-->
    <section class="content">
        @RenderBody()
    </section>
    <!--End of content-->
    <!--Begin of footer-->
    <div class="section" style="background-color:#01A14B;">
        <div class="row" style="padding:0px; margin:0;">
            <p class="mb-0" style="color: rgba(255,255,255,.5);">
                <!-- Link back to Colorlib can't be removed. Template is licensed under CC BY 3.0. -->
                Copyright &copy;
                <script>document.write(new Date().getFullYear());</script> All rights reserved | This template is made with <i class="fa fa-heart color-danger" aria-hidden="true"></i> by <a class="linkFooter" href="https://nxbdhsp.edu.vn" target="_blank">ATC Group</a>
                <!-- Link back to Colorlib can't be removed. Template is licensed under CC BY 3.0. -->
            </p>
            <p class="mb-0" style="color: rgba(255,255,255,.5);">
                Lượt truy cập: 000.000 | Đang truy cập: 000.000
            </p>
        </div>

    </div>
    <!--End of footer-->
     

</body>

</html>

 <script src="~/js/talk.js"></script>

<script src="~/js/bootstrap.min.js"></script>
<script src="~/js/slick.min.js"></script>
<script src="~/js/nouislider.min.js"></script>
<script src="~/js/jquery.zoom.min.js"></script>
<script src="~/js/main.js"></script>
