    <link rel="stylesheet" href="~/Styles/skin.css" />

    @*<link rel="stylesheet" href="~/Styles/jquery_ui_datepicker.css" />*@


    <script src="~/Scripts/jquery.min.js"></script>
    <script src="~/Scripts/jquery-ui.min.js"></script>

    @*<script src="~/Scripts/jquery_ui_datepicker.js"></script>*@

    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Scripts/jquery.slimscroll.min.js"></script>
    <script src="~/Scripts/validator.min.js"></script>
    <script src="~/Scripts/lib/admin.min.js"></script>

    <script src="~/Scripts/jquery.dataTables.min.js"></script>
    <script src="~/Scripts/dataTables.bootstrap.min.js"></script>
    @* <script src="~/Scripts/dataTables.buttons.min.js"></script>
        <script src="~/Scripts/buttons.html5.min.js"></script>*@

    <script src="~/Scripts/jszip.min.js"></script>
    @*<script src="~/Scripts/jszip.min.js"></script>*@
    <script src="~/Scripts/buttons.print.min.js"></script>
    <script src="~/Scripts/xlsx.core.min.js"></script>
    <script src="~/Scripts/xls.core.min.js"></script>

    <script src="~/Scripts/select2.min.js"></script>
    <link href="~/Styles/select2.min.css" rel="stylesheet" />

    <link href="~/KendoUI/kendo.common.min.css" rel="stylesheet">

    <link href="~/KendoUI/kendo.default.min.css" rel="stylesheet">
    <link href="~/KendoUI/kendo.default.mobile.min.css" rel="stylesheet">

     

    <link href="~/Styles/common.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/Styles/bill.css">

    <script src="~/kendoui/js/kendo.all.min.js"></script>
    @*<script src="~/kendoui/js/jszip.min.js"></script>*@

    <script src="~/Scripts/angular.min.js"></script>
    <script src="~/Scripts/angular-sanitize.js"></script>
    @*<script src="~/Scripts/ngStorage.min.js"></script>*@
    <script src="~/Scripts/jquery.number.min.js"></script>
    <script src="~/Scripts/jquery.fullscreen.min.js"></script>
    <!--THong tin cho soan thao van ban -->
    <script src="~/CKeditor/ckeditor/ckeditor.js" charset="utf-8" type="text/javascript"></script>
    <script src="~/CKeditor/" type="text/javascript"></script>


    <script>
    @Html.Raw(File.ReadAllText(Server.MapPath("~/Scripts/common.js")))
    @Html.Raw(File.ReadAllText(Server.MapPath("~/App/mrictotal.js")))

    </script>

    <script src="~/Scripts/shortcut.js"></script>


    <link rel="stylesheet" href="~/Styles/w3.css">

</head>

<body style="margin-left:0px; margin-top:0px; background-color:#ffffff;">
    <!--Thong tin top-->
    <div class="section" style="background-color:#ffffff;  ">
        <div class="row VerticalAlignStyle1" style="padding:0px; margin:0">
            <div class="col-lg-5 col-xs-12">
                <div class="row">
                    <div class="hidden-xs outer">
                        <div class="inner">
                            <a href="/Home/1">
                                <img src="~/Images/home.png" style="width:30px" />
                            </a>
                        </div>
                    </div>

                    <div class="outer">
                        <div class="inner">
                            &nbsp; <i class="glyphicon glyphicon-phone-alt"></i> &nbsp; 0222.390.2426 <span class="fusion-header-separator">|</span>
                            &nbsp; <i class="fa fa-fax"></i> : 0222.390.2426<span class="fusion-header-separator">&nbsp; |&nbsp; </span>
                            <span>
                                <i class="fa fa-envelope"></i> &nbsp;    <a class="info" href="mailto: atc@samsung.com"> atc@samsung.com</a>

                            </span>
                            &nbsp;
                            <span class="linkheader1">
                                <a class="linkheader1" href="/Chat/1">  <i class="fa fa-commenting">&nbsp;Chat</i></a>
                            </span>
                        </div>
                    </div>

                </div>
            </div>
            <div class="col-lg-4">
                <div class="outer">
                    <div class="inner">
                        Data updated: @ViewBag.UpdateTime; current time: <i class="fa fa-clock-o"> <span id="clock" style="font-weight:800;"></span></i>
                    </div>
                </div>
            </div>
            <div class="hidden-xs col-lg-3 col-xs-12">
                <div class="row">
                    @Html.Partial("menu_top")
                </div>
            </div>
        </div>
    </div>
    <!--End of top-->
    <!--Begin of information of Head-->
    <div class="section" style="background-color:#01A14B; border-top:2px solid #ffffff;">
        <div class="row topnav" style="padding:0; margin:0">
            <div class="w3-teal" style="float:left">
                <button id="openNav" class="w3-button w3-teal w3-xlarge" style="padding:5px;" onclick="w3_open()">&#9776;</button>
            </div>
            <div style="float:left">
                @Html.Partial("_header")
            </div>
            <div class="search-container">
                <input type="text" id="txtcontentsearch" placeholder="Search.." name="search">
                <button type="submit" id="cmdSearch"><i class="fa fa-search"></i></button>
            </div>
        </div>
    </div>
    <!--End of menu head-->
    <section class="content">
        <div class="row w3-sidebar w3-bar-block w3-card w3-animate-left" style="display:none" id="mySidebar">
            <button  class="w3-bar-item w3-button w3-large"
                    onclick="w3_close()">
                Close &times;
            </button>
            <ul class="sidebar-menu" data-widget="tree" data-accordion=0 data-api="tree">
                @Html.Raw(ViewBag.ProjectOnHome)
            </ul>
        </div>

        <div class="row" id="main">
            @RenderBody()
        </div>
    </section>

    <!--Begin of footer-->
    <div class="section" style="background-color:#01A14B;">
        <div class="row" style="padding:0px; margin:0;">
            <p class="mb-0" style="color: rgba(255,255,255,.5);">
                <!-- Link back to Colorlib can't be removed. Template is licensed under CC BY 3.0. -->
                Copyright &copy;
                <script>document.write(new Date().getFullYear());</script> All rights reserved | This template is made with <i class="fa fa-heart color-danger" aria-hidden="true"></i> by <a class="linkFooter" href="https://nxbdhsp.edu.vn" target="_blank">ATC Group</a>
                <!-- Link back to Colorlib can't be removed. Template is licensed under CC BY 3.0. -->
            </p>
            <p class="mb-0" style="color: rgba(255,255,255,.5);">
                Lượt truy cập: 000.000 | Đang truy cập: 000.000
            </p>
        </div>

    </div>
    <!--End of footer-->
    <div id="dialog"></div>



    <script>
        function w3_open() {
            document.getElementById("main").style.marginLeft = "25%";
            document.getElementById("mySidebar").style.width = "25%";
            document.getElementById("mySidebar").style.display = "block";
            document.getElementById("openNav").style.display = 'none';
        }
        function w3_close() {
            document.getElementById("main").style.marginLeft = "0%";
            document.getElementById("mySidebar").style.display = "none";
            document.getElementById("openNav").style.display = "inline-block";
        }
    </script>

    <script>

     $(document).ready(function () {
        
          setInterval(time, 1000);

                setInterval(function () {
                    location.reload();
                }, 1000 * 60 * 20);  //10.000 ms = 1s

     });
    function time() {
                var d = new Date();
                var s = d.getSeconds();
                var m = d.getMinutes();
                var h = d.getHours();
                $('#clock').text(h + ':' + m + ':' + s);

            }

    </script>







</body>

</html>

