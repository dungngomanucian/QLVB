<body class="hold-transition skin-green-light sidebar-mini fixed" ng-app="mtmain">


    <div class="wrapper">

        <header class="main-header">
            <!-- Logo -->
            <a href="~/" class="logo">
                <!-- mini logo for sidebar mini 50x50 pixels -->
                <span class="logo-mini"><img src="/Areas/Admin/images/logofit.png" alt="Về trang chủ | Quản lý văn bản" class="home_logo_small"/></span>
                <!-- logo for regular state and mobile devices -->
                <span class="logo-lg">
<img src="/Areas/Admin/images/logofit.png" alt="Về trang chủ | Quản lý văn bản" class="home_logo"/>

                </span>
            </a>
            <!-- Header Navbar: style can be found in header.less -->
            <nav class="navbar navbar-static-top">
                <!-- Sidebar toggle button-->
                <a href="#" class="sidebar-toggle" data-toggle="push-menu" role="button">
                    <span class="sr-only">Toggle navigation</span>
                </a>

                <div class="navbar-default">

                </div>

                <div class="navbar-custom-menu">
                    <ul class="nav navbar-nav">
                   
                        <li class="hidden-sm hidden-xs"><a href="@ViewBag.lang_link"> <img src="@ViewBag.lang_img" /> @ViewBag.lang_text</a> </li>
                         
                        <li class="hidden-sm hidden-xs" style="padding-top:10px;display:none">
                            <select id="cbbmain_chinhanh" style="padding:3px;max-width: 150px;">
                                
                            </select>

                        </li>
                        <!-- User Account: style can be found in dropdown.less -->
                        <li class="dropdown user user-menu">
                            <a href="#" class="dropdown-toggle" data-toggle="dropdown">
                                <img src="~/Areas/Admin/@ViewBag.user_avata" class="user-image" alt="User Image">
                                <span class="hidden-xs">@ViewBag.user_uid     </span>
                            </a>
                            <ul class="dropdown-menu">
                                <!-- User image -->
                                <li class="user-header">
                                    <img src="~/Areas/Admin/@ViewBag.user_avata" class="img-circle" alt="User Image">
                                    <p>
                                        @ViewBag.user_fullname
                                        <small>Member since @ViewBag.user_fromdate</small>
                                    </p>
                                </li>
                              

                                <li class="user-footer" style="background-color:#3c8dbc;border-top:1px solid #fff;">
                                    <div class="pull-left">
                                        <a href="#"  id="cmdchangepassword" class="btn btn-default btn-flat">Đổi mật khẩu</a>
                                    </div>
                                    <div class="pull-right">
                                        <a href="/Admin/Logout" class="btn btn-default btn-flat">Thoát</a>
                                    </div>
                                </li>
                            </ul>
                        </li>
                       

                    </ul>
                </div>
            </nav>
        </header>
        <!-- Left side column. contains the logo and sidebar -->
        <aside class="main-sidebar">
            <!-- sidebar: style can be found in sidebar.less -->
            <section class="sidebar">
                <!-- Sidebar user panel -->
               
                <!-- /.search form -->
                <!-- sidebar menu: : style can be found in sidebar.less -->
                <ul class="sidebar-menu" data-widget="tree" data-accordion=0 data-api="tree" >
                    @*<li class="header">MAIN MENU    </li>*@
                    @Html.Raw(ViewBag.UserMenu)
                </ul>
            </section>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Content Header (Page header) -->
            <section class="content-header">
                <h1 style="text-transform:uppercase;">
                    @ViewBag.Function_Title
                    @*<small>Control panel</small>*@
                </h1>
             
                <ol class="hidden-sm hidden-xs breadcrumb">
                   
                    <li id="liInternetAvailable" class="internet_online"><i class="fa fa-cloud-upload"></i></li>
                    <li><a href="~/Admin/Home"><i class="fa fa-dashboard"></i> Home</a></li>
                    <li class="active"><a href="~/@ViewBag.ControllerName">@ViewBag.Function_Title_Short</a></li>
                </ol>
            </section>

            <!-- Main content -->
            <section class="content" style="padding:0px 10px;">
                <div class="row">
                    <div class="col-lg-12 col-xs-12">

                        @RenderBody()
                    </div>
                </div>
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <footer class="main-footer">
            <div class="pull-right hidden-xs">
                <b>Version</b> @Html.Raw(ViewBag.Version)
            </div>
            <strong>@Html.Raw(ViewBag.Copyright)</strong>
            @*<strong>Copyright &copy; 2008-2019 <a href="http://cpavietnam.vn/"> Software</a>.</strong>*@
        </footer>

        <!-- Control Sidebar -->
        <aside class="control-sidebar control-sidebar-light">
            <!-- Create the tabs -->
            <ul class="nav nav-tabs nav-justified control-sidebar-tabs">
                <li><a href="#control-sidebar-home-tab" data-toggle="tab"><i class="fa fa-home"></i></a></li>
                <li><a href="#control-sidebar-settings-tab" data-toggle="tab"><i class="fa fa-gears"></i></a></li>
            </ul>
            <!-- Tab panes -->
            <div class="tab-content">
                <!-- Home tab content -->
                <div class="tab-pane" id="control-sidebar-home-tab">

                </div>
                <!-- /.tab-pane -->
                <!-- Stats tab content -->
                <div class="tab-pane" id="control-sidebar-stats-tab">Stats Tab Content</div>
                <!-- /.tab-pane -->
                <!-- Settings tab content -->
                <div class="tab-pane" id="control-sidebar-settings-tab">

                </div>
                <!-- /.tab-pane -->
            </div>
        </aside>
        <!-- /.control-sidebar -->
        <!-- Add the sidebar's background. This div must be placed
             immediately after the control sidebar -->
        <div class="control-sidebar-bg"></div>
    </div>

    @Html.Raw(File.ReadAllText(Server.MapPath("~/Areas/Admin/Content/common_dialog.html")))

 <script>
  //$('[data-toggle="push-menu"]').pushMenu('toggle');
 </script>

    <script type="x/kendo-template" id="page-template">
        <div class="page-template">
            <div class="header">
                <div style="float: right">Page #: pageNum # of #: totalPages #</div>
                @Html.Raw(ViewBag.Function_Title)
            </div>
            <div class="watermark">PHẦN MỀM QUẢN LÝ VĂN BẢN</div>
            <div class="footer">
                Page #: pageNum # of #: totalPages #
            </div>
        </div>
    </script>

    <script>
    bill_nvid_logined = '@ViewBag.login_nv_id';
    </script>
</body>

</html>

