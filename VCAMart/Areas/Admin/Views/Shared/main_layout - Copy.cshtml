@{

    Layout = null;
    ViewBag.url = System.Configuration.ConfigurationManager.AppSettings["url"].ToString();

    ViewBag.Version = "2019";
    try
    {
        ViewBag.Copyright =  ViewBag.hansudung + ViewBag.congty_ten + " - Copyright &copy; 2008-2019 <a href='http://cpavietnam.vn'> Software</a>.";
    }
    catch(Exception e)
    {
        ViewBag.Copyright = "Copyright &copy; 2008-2019 <a href='http://cpavietnam.vn'> Software</a>.";
    }

    ViewBag.ngaygio = DateTime.Now.ToString();
}



