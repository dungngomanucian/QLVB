    //-------------end edit a record

    //------------- valid  a record
    function IsValid() {

        _row.id = _EDIT_ID;
        _row.CC_Id = _EDIT_ID;

        _row.CC_ParentId = $('#cbbCC_ParentId').val();
        _row.CC_Name = $('#txtCC_Name').val();
        _row.CC_FriendlyUrl = $('#txtCC_FriendlyUrl').val();
        _row.CC_LinkWebsite = $('#txtCC_LinkWebsite').val();
        _row.CC_Image = $('#txtCC_Image').val();
        _row.CC_Description = $('#txtCC_Description').val();
        _row.CC_SortOrder = $('#txtCC_SortOrder').val();
        _row.CC_Position = $('#txtCC_Position').val();
        _row.CC_Status = $('#txtCC_Status').val();
        _row.CC_PageTitle = $('#txtCC_PageTitle').val();
        _row.CC_MetaKeyword = $('#txtCC_MetaKeyword').val();
        _row.CC_MetaDescription = $('#txtCC_MetaDescription').val();
        _row.CC_System = $('#txtCC_System').val();
        _row.CC_Notes = $('#txtCC_Notes').val();

        _row.active = ($("#ckstatus").is(':checked') ? 1 : 0);
        _row.TrangThai = ($("#ckstatus").is(':checked') ? 'Đang sử dụng' : 'Không sử dụng');

        _row.ten  =$('#cbbCC_ParentId option:selected').text();

        //_row.active = ($("#ckstatus").is(':checked') ? 1 : 0);
        msg = '';
        if (_row.CC_Name == '')
            msg += '\n+ Tên chủ đề không được để trống';


        if (msg != '') {
           $('#lbthongbao').html('Error: ' + msg);
            return false;
        }

        return true;
    }
    //------------- end valid a record
    function _getGroupName(obj)
    {
        var s = '';
        for (i = 0; i < obj.length; i++)
        {
            s += '<span class="groupname" >' + obj[i] + '</span>';
        }
        return s;
    }

    function _showGrid() {


       var crudServiceBaseUrl = controllerURL;



        $("#grid_noidung").kendoGrid({
            dataSource: {
                transport: {
                    read: {
                        url: crudServiceBaseUrl + "/GetList/" + js_mn_tt,
                        dataType: "json"
                    }
                },

                //data: data,
                schema: {
                    parse : function(data) {
                                return data.data;
                        }
                },
                pageSize: @ViewBag.pagesize
            },
            filterable: {
               // mode:"row",
                extra: false,
                operators: {
                    string: {
                        contains: "Contains...",
                        startswith: "Starts with",
                        eq: "Is equal to"
                        //, neq: "Is not equal to"
                    }
                }
            },

            // height: 500,
            //toolbar: ["excel"],
            scrollable: false,
            sortable: { mode: "multiple", allowUnsort: true },
            pageable: { input: false, numeric: true },
            reorderable: true,
            resizable: true,
            groupable: true,
            allowCopy: true,
            selectable: "multiple cell",
            excel: {
                fileName: exportFileName + ".xlsx",
                allPages: true,
                filterable: true
            },
            pdf: {
                author: "RIC Total",
                creator: "RIC Total",
                date: new Date(),
                fileName: exportFileName + ".pdf",
                subject: "RIC Total: " + exportFileName,
                title: "RIC Total: " + exportFileName,
                margin: { left: "20pt", right: "20pt", top: "15mm", bottom: "15mm" },
                paperSize: "A4",
                landscape: true,
                scale: 0.8,
                avoidLinks: true,
                repeatHeaders: true,
                template: $("#page-template").html(),
                allPages: true
            },

            columns: [
                {field: "id", title: "No.", template: "#= ++recordnumber#", filterable: false   , sortable: false},
                {
                    title: "<input type=checkbox id='ckcheckall' onclick='_checkAll();'>"
                    , template: "<input type=checkbox value='#=id#'>"               , filterable: false , sortable: false
                }, {
                    title: ""
                    , template: "<a href='javascript://' class='bg-green' title='Thông tin chi tiết => Sửa'  style='padding:5px;' onclick=' _editItem(\"#=id#\",\"#= recordnumber #\")'  data-toggle='modal' data-target='\\#dlg@(ViewBag.tblname)'><i class='fa fa-edit'></a>"
                    , filterable: false  , sortable: false
                },
              //  { field: "ten", title: "Chủ đề cha", filterable: { cell: { operator: "contains" } } },
                { field: "CC_Name", title: "Tên chủ đề", filterable: { cell: { operator: "contains" } } },
             //   { field: "tel", title: "Điện thoại", filterable: { cell: { operator: "contains" } } },
             //   {title: "Nhóm quyền", template: "#= _getGroupName(qten) #",  filterable: false , sortable: false},

              //  { field: "TrangThai", title: "Trạng thái"}

       ],
            dataBound: function (e) {
                recordnumber = 0;
                for (var i = 0; i < this.columns.length; i++) this.autoFitColumn(i);
            }
        }) ;

         grid = $("#grid_noidung").data("kendoGrid");
    }




    function _gridUpdateItem() {

        var grid = $("#grid_noidung").data("kendoGrid");
        var dataSource = grid.dataSource;
        var dataItem = grid.dataItem("tbody tr:eq(" + _EDIT_INDEX + ")"); //get data
        dataItem["CC_Name"] = _row.CC_Name;
        dataItem["CC_ParentId"] = _row.CC_ParentId;
        dataItem["ten"] = _row.ten;
        dataItem["CC_FriendlyUrl"] = _row.CC_FriendlyUrl;
        dataItem["CC_LinkWebsite"] = _row.CC_LinkWebsite;
        dataItem["CC_Image"] = _row.CC_Image;
        dataItem["CC_Description"] = _row.CC_Description;
        dataItem["CC_SortOrder"] = _row.CC_SortOrder;
        dataItem["CC_Position"] = _row.CC_Position;
        dataItem["CC_Status"] = _row.active;
        dataItem["CC_PageTitle"] = _row.CC_PageTitle;
        dataItem["CC_MetaKeyword"] = _row.CC_MetaKeyword;
        dataItem["CC_MetaDescription"] = _row.CC_MetaDescription;
        dataItem["CC_Published"] = _row.CC_Published;
        dataItem["CC_Notes"] = _row.CC_Notes;



        grid.refresh();
    }
    //-------------end edit a record


</script>