
@{
    ViewBag.Title = "View";
    Layout = "~/Areas/Admin/Views/Shared/main_layout.cshtml";
}





<div class="box" style="margin-top: 1px; margin-left:1px;" id="divcontent">
    <div class="box-header">
        <label id="lbcontent_title" style="display:none;">@(ViewBag.Function_Title)</label>
        <a id="cmdadd_cate" class="btn bg-green btn-flat " data-toggle="modal" data-target="#dlg@(ViewBag.tblname)"> <i class="fa fa-plus"></i> &nbsp;Thêm </a>
        <a id="cmddelete_cate" class="btn bg-red btn-flat ">      <i class="fa fa-remove"></i> &nbsp;Xóa </a>
        <a id="cmdprint_cate" class="btn bg-fuchsia  btn-flat ">      <i class="fa fa-print"></i> &nbsp;Print </a>

        <a id="cmdexport2excel" class="btn bg-blue btn-flat" title="Save 2 Excel">      <i class="fa fa-file-excel-o"></i> &nbsp;Excel</a>
        <a id="cmdexport2pdf" class="btn bg-aqua btn-flat" title="Save 2 PDF">      <i class="fa fa-file-pdf-o"></i> &nbsp;PDF </a>
        <a id="cmdactive" class="btn bg-olive btn-flat" title="Active/DeActive">      <i class="fa fa-check-square-o"></i> &nbsp;Active/DeActive </a>




        <a class="btn_endfullscreen" style="display:none;"><i class="fa fa-close"></i></a>
        <a class="btn_fullscreen"><i class="glyphicon glyphicon-fullscreen"></i></a>

    </div>

    <div class="box-body">
        <div id="grid_noidung"></div>

    </div>
</div>

<form id="frm@(ViewBag.tblname)">
    <div class="modal fade" id="dlg@(ViewBag.tblname)" data-backdrop="static" data-keyboard="false" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h3 class="modal-title">Quản lý chuyên mục</h3>
                </div>
                <div id="lbthongbao" style="color:red;padding:0px  10px;"></div>
                <div class="modal-body">
                    <div class="box-body">

                        <div class="form-group">
                            <label for="cbbCC_ParentId" class="col-sm-4 control-label">Chủ đề cha:</label>
                            <div class="col-sm-8">
                                <select id="cbbCC_ParentId" class="form-control" style="width:100%;"></select>

                            </div>
                        </div>

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_Name" class="col-sm-4 control-label">Tên nhóm:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_Name" placeholder="tên nhóm">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_FriendlyUrl" class="col-sm-4 control-label">Địa chỉ URL:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_FriendlyUrl" placeholder="">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_LinkWebsite" class="col-sm-4 control-label">Liên kết website:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_LinkWebsite" placeholder="">
                            </div>
                        </div>

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_Description" class="col-sm-4 control-label">Mô tả:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_Description" placeholder="">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_SortOrder" class="col-sm-4 control-label">Thứ tự sắp xếp:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_SortOrder" placeholder="">
                            </div>
                        </div>

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_Position" class="col-sm-4 control-label">Vị trí:</label>
                            <div class="col-sm-8">
                                <select id="txtCC_Position" class="form-control"></select>

                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_Status" class="col-sm-4 control-label">Trạng thái:</label>
                            <div class="col-sm-8">
                                <select id="txtCC_Status" class="form-control"></select>

                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_PageTitle" class="col-sm-4 control-label">Tiêu đề trang:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_PageTitle" placeholder="">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_MetaKeyword" class="col-sm-4 control-label">Từ khóa:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_MetaKeyword" placeholder="">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_MetaDescription" class="col-sm-4 control-label">Từ khóa mô tả:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_MetaDescription" placeholder="">
                            </div>
                        </div>

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_Notes" class="col-sm-4 control-label">Ghi chú:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtCC_Notes" placeholder="">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="ckstatus" class="col-sm-4 control-label">Kiểm duyệt:</label>
                            <div class="col-sm-8">

                                <input type="checkbox" id="ckstatus" />
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtCC_Image" class="col-sm-4 control-label">Ảnh đại diện:</label>
                            <div class="col-sm-8">
                                <table border="0" style="width:100%">
                                    <tr>
                                        <td><input id="txtCC_Image" class="input-control" name="txtCC_Image" type="text" /></td>
                                        <td><button id="chonanhbia" class="btn btn-default">  Chọn tệp tin  </button></td>
                                    </tr>
                                </table>
                            </div>
                            <div>

                            </div>
                        </div>
                    </div>


                    <div class="modal-footer">
                        <button type="button" class="btn bg-red pull-right" data-dismiss="modal"><i class="fa fa-close"></i>  Đóng</button>
                        <button type="button" class="btn bg-green pull-left" id="cmdsave_cate"><i class="fa fa-save"></i>&nbsp; Lưu</button>
                    </div>
                </div>
                <!-- /.modal-content -->
            </div>
            <!-- /.modal-dialog -->
        </div>
    </div>
    <!-- /.modal -->
</form>


