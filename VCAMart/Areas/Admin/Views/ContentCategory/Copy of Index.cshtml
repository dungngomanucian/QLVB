   // load du lieu ra form de sua
    function _editItem(obj, rowindex) {
        $('#lbthongbao').html('');

        // $('#txtma').prop('readonly', true);
        disableHideObjects();
        bAddEdit = false;
       // var row = jsonData[rowindex];
        var row = grid.dataItem("tbody tr:eq(" + (rowindex - 1) + ")"); //get data
        bAddEdit = false;
        _EDIT_INDEX = rowindex-1;
        _EDIT_ID = row.id;

        $('#cbbCC_ParentId').val(row.CC_ParentId);
        $('#txtCC_Name').val(row.CC_Name);
        $('#txtCC_FriendlyUrl').val(row.CC_FriendlyUrl);
        $('#txtCC_LinkWebsite').val(row.CC_LinkWebsite);
        $('#txtCC_Image').val(row.CC_Image);

        $('#txtCC_Description').val(row.CC_Description);
        $('#txtCC_SortOrder').val(row.CC_SortOrder);
        $('#txtCC_Position').val(row.CC_Position);
        $('#txtCC_Status').val(row.CC_Status);
        $('#txtCC_PageTitle').val(row.CC_PageTitle);
        $('#txtCC_MetaKeyword').val(row.CC_MetaKeyword);
        $('#txtCC_MetaDescription').val(row.CC_MetaDescription);
        $('#txtCC_System').val(row.CC_System);
        $('#txtCC_Notes').val(row.CC_Notes);

        $('#ckstatus').prop('checked', (row.active / 1 == 1 ? true : false));

      //  $('#ckstatus').prop('checked', (row.active / 1 == 1 ? true : false));

       // $('#cbbCC_ParentId').val(row.qid);
        $("#cbbCC_ParentId").trigger("change");
       // $("#cbbUser_CV_Id").trigger("change");

