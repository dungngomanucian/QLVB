
@{
    ViewBag.Title = "View";
    Layout = "~/Views/Shared/main_layout.cshtml";
}
 
 
 <div class="box" style="margin-top: 1px; margin-left:1px;">
    <div class="box-header">
      <a id="cmdadd" class="btn bg-olive btn-flat " data-toggle="modal" data-target="#EV_Dlg"> <i class="fa fa-plus"></i> &nbsp;Thêm </a>
        <a id="cmddelete" class="btn bg-olive btn-flat ">      <i class="fa fa-remove"></i> &nbsp;Xóa </a>
       
    </div>

    <div class="box-body">

        <table id="tblSysMenu" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th> </th>
                    <th><input type="checkbox" id="ck_all" class="checkbox" /></th>
                    <th>Parent</th>
                    <th>Tên</th>
                    <th>Thứ tự</th>
                    <th>URL</th>
               <th>ICON</th>
                    <th>Group</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                
        </table>
    </div>
     </div>
 
<form id="frmtblSysMenu" >
    <div class="modal fade" id="EV_Dlg" data-backdrop="static" data-keyboard="false" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h3 class="modal-title">Quản lý Menu Hệ thống</h3>
                </div>
                <div id="lbthongbao" style="color:red;padding:0px  10px;"></div>
                <div class="modal-body">
                    <div class="box-body">
                        <div class="form-group" style="padding-top:25px;">
                            <label for="cbbcha" class="col-sm-4 control-label">Parent:</label>
                            <div class="col-sm-8">
                                <select id="cbbcha" class="form-control" style="width:100%;"></select>
                            </div>
                        </div>
 
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtten" class="col-sm-4 control-label">Tên:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" required id="txtten" placeholder="Tên ">
                            </div>
                        </div>

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtmota" class="col-sm-4 control-label">Mô tả:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtmota" placeholder="Mô tả ">
                            </div>
                        </div>

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtthutu" class="col-sm-4 control-label">Thứ tự:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtthutu" placeholder="Mô tả ">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txturl" class="col-sm-4 control-label">URL:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txturl" placeholder="URL">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txticon" class="col-sm-4 control-label">ICON:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txticon" placeholder="ICON">
                            </div>
                        </div>

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txttarget" class="col-sm-4 control-label">Target:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txttarget" placeholder="Target">
                            </div>
                        </div>
     
                        <div class="form-group" style="padding-top:25px;">
                            <label class="col-sm-4 control-label">Status :</label>
                            <div class="col-sm-8">
                                <input type="checkbox" id="ckstatus" />
                                &nbsp;&nbsp;&nbsp;&nbsp;Direct:&nbsp;
                                <input type="checkbox" id="ckdirect" />
                                &nbsp;&nbsp;&nbsp;&nbsp;BeginGroup:&nbsp;<input type="checkbox" id="ckbegingroup" />
                            </div>
                        </div>
                        @*<div class="form-group" style="padding-top:25px;">
                            <label class="col-sm-4 control-label">Update  :</label>
                            <div class="col-sm-8">
                                <input type="checkbox" id="ckstatus" />
                                &nbsp;&nbsp;&nbsp;&nbsp;Direct:&nbsp;
                                <input type="checkbox" id="ckdirect" />
                                &nbsp;&nbsp;&nbsp;&nbsp;BeginGroup:&nbsp;<input type="checkbox" id="ckbegingroup" />
                            </div>
                        </div>*@
                </div>


                <div class="modal-footer">
                    <button type="button" class="btn btn-default pull-right" data-dismiss="modal"><i class="fa fa-close"></i>  Đóng</button>
                    <button type="submit" class="btn btn-primary pull-left" id="cmdsave"><i class="fa fa-save"></i>&nbsp; Lưu</button>
                </div>
            </div>
            <!-- /.modal-content -->
        </div>
        <!-- /.modal-dialog -->
    </div>
        </div>
    <!-- /.modal -->
</form>
<style type="text/css">
