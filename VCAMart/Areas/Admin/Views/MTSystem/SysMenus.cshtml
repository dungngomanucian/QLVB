<script type="text/javascript">


    function InitDefault() {
        columnsWidth = [{ sWidth: '5%' }, { sWidth: '10%' }, { sWidth: '15%' }, { sWidth: '20%' }, { sWidth: '10%' }, { sWidth: '15%' }, { sWidth: '15%' }, { sWidth: '5%' }, { sWidth: '5%' }];
        columnAutoWidth = false;
        bLoadDataCommon = true;

        title = '@Html.Raw(ViewBag.Function_Title)';
        document.title = '@Html.Raw(RICTotal.Models.common.app_title_short)' + " - " + title;

        myVersion = 2;
          jsonData= []; // chua du lieu can bind ra bang
          urlobj;
          bAddEdit = true; // true: add, false: edit
          controllerURL =  '/SysMenus';
          tblData = 'tblSysMenu'; // tên bảng show dữ liệu
          dlgAddEdit = 'EV_Dlg'; // dialog chữa form edit
          TienTo = ''; // tên trường tiền tố của 1 bảng

          _row = {
              id: ""
              , thutu: ""
              , muc: ""
              , parentid: ""
              , parentten: ""
              , ten: ""
              , mota: ""
              , url: ""
              , icon: ""
              , target: ""
              , direct: 0
              , begingroup: 0
              , active: 0
              , update: 0
          };
    }

    // khoi tao cac gia tri mac dinh khi addnew sau khi reset
    function InitDefaultValue() {
        $('#txtpagesize').val(10);
        $('#ckstatus').prop('checked', true);
        $('#ckdirect').prop('checked', false);
        $('#ckbegingroup').prop('checked', false);
        $('#txttarget').val('_blank');
    }


    $(document).ready(function () {
       //  GetParentMenus('cbbcha');
        loadComboNhom('cbbcha', "/Common/GetParentMenus", 'id', 'ten',"");
        
        $('#frmtblSysMenu').validator().on('submit', function (e) {
            if (e.isDefaultPrevented()) {
            } else {

                return false;
            }
        })

    });

    function disableHideObjects()
    {
       // $('#txtuid').attr('disabled', true);
    }

   // load du lieu ra form de sua
    function _edit(obj, rowindex) {
        $('#lbthongbao').html('');

        // $('#txtma').prop('readonly', true);
        disableHideObjects();
        bAddEdit = false;
        var row = jsonData[rowindex];
        _EDIT_INDEX = rowindex;
        _EDIT_ID = row.id;

        $('#txtten').val(row.ten);
        $('#txtthutu').val(row.thutu);
        $('#txtmota').val(row.mota);
        $('#txturl').val(row.url);
        $('#txticon').val(row.icon);
        $('#txttarget').val(row.target);

        $('#ckstatus').prop('checked', (row.active / 1 == 1 ? true : false));
        $('#ckdirect').prop('checked', (row.direct / 1 == 1 ? true : false));
        $('#ckbegingroup').prop('checked', (row.begingroup / 1 == 1 ? true : false));

        $('#cbbcha').val(row.parentid);

    }
    //-------------end edit a record

    //------------- valid  a record
    function IsValid() {

        _row.id = _EDIT_ID;

        _row.ten = $("#txtten").val();
        _row.mota = $("#txtmota").val();
        _row.url = $("#txturl").val();
        _row.target = $("#txttarget").val();
        _row.thutu = $("#txtthutu").val();
        _row.icon = $("#txticon").val();

        _row.active = ($("#ckstatus").is(':checked') ? 1 : 0);
        _row.direct = ($("#ckdirect").is(':checked') ? 1 : 0);
        _row.begingroup = ($("#ckbegingroup").is(':checked') ? 1 : 0);

        _row.parentid = $("#cbbcha").val();

        // chuan hoa xau
        _row.ten = _row.ten.replace(reg, '');
        _row.mota = _row.mota.replace(reg, '');
        _row.url = _row.url.replace(reg, '');
        _row.target = _row.target.replace(reg, '');
        _row.icon = _row.icon.replace(reg, '');
        _row.thutu = _row.thutu.replace(reg, '');

        msg = '';
        if (bAddEdit)
        {
            if (_row.ten == '') msg += '\n- Cần vào Tên menu;';
        }

        if (msg != '') {
           $('#lbthongbao').html('Error: ' + msg);
            return false;
        }

        return true;
    }

    function GetRow(item) {
        var s = '';
        s += '<td>' + item.parentten + '</td>';
        s += '<td>' + item.ten+ '</td>';
        s += '<td>' + item.thutu + '</td>';
        s += '<td>' + item.url + '</td>';
        s += '<td>' + item.icon + '</td>';
        s += '<td>' + item.begingroup + '</td>';
        s += '<td>' + item.active + '</td>';
        return s;
    }

</script>