
@{
    ViewBag.Title = "View";
    Layout = "~/Areas/Admin/Views/Shared/main_layout.cshtml";
}


<div class="box" style="margin-top: 1px; margin-left:1px;">
      <div class="box-header">
        <label id="lbcontent_title" style="display:none;">@(ViewBag.Function_Title)</label>
        <a id="cmdadd_cate" class="btn bg-green btn-flat " data-toggle="modal" data-target="#dlg@(ViewBag.tblname)"> <i class="fa fa-plus"></i> &nbsp;Thêm </a>
        <a id="cmddelete_cate" class="btn bg-red btn-flat ">      <i class="fa fa-remove"></i> &nbsp;Xóa </a>
        <a id="cmdprint_cate" class="btn bg-fuchsia  btn-flat ">      <i class="fa fa-print"></i> &nbsp;Print </a>
        <a id="cmdexport2excel" class="btn bg-blue btn-flat" title="Save 2 Excel">      <i class="fa fa-file-excel-o"></i> &nbsp;Excel</a>
        <a id="cmdexport2pdf" class="btn bg-aqua btn-flat" title="Save 2 PDF">      <i class="fa fa-file-pdf-o"></i> &nbsp;PDF </a>

        <a class="btn_endfullscreen" style="display:none;"><i class="fa fa-close"></i></a>
        <a class="btn_fullscreen"><i class="glyphicon glyphicon-fullscreen"></i></a>

    </div>

    <div class="box-body">
        <div id="grid_noidung"></div>

    </div>
</div>

<form id="frm@(ViewBag.tblname)">
    <div class="modal fade" id="dlg@(ViewBag.tblname)" data-backdrop="static" data-keyboard="false" role="dialog">
        <div class="modal-dialog" style="width:800px;">
            <div class="modal-content" >
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h3 class="modal-title">Nhóm quyền</h3>
                </div>
                <div id="lbthongbao" style="color:red;padding:0px  10px;"></div>
                <div class="modal-body">
                    <div class="box-body">
                 

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtten" class="col-sm-4 control-label">Tên:</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" required id="txtten" placeholder="Tên ">
                            </div>
                        </div>
 

                        <div class="form-group" style="padding-top:25px;">
                            <label for="ckstatus" class="col-sm-4 control-label">Status :</label>
                            <div class="col-sm-8">
                                <input type="checkbox" id="ckstatus" />
                             
                            </div>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn bg-red pull-right" data-dismiss="modal"><i class="fa fa-close"></i>  Đóng</button>
                        <button type="button" class="btn bg-green pull-left" id="cmdsave_cate"><i class="fa fa-save"></i>&nbsp; Lưu</button>
                    </div>
                </div>
                <!-- /.modal-content -->
            </div>
            <!-- /.modal-dialog -->
        </div>
    </div>
    <!-- /.modal -->    
</form>

 


<div class="modal fade" id="divphanquyen" style="display:none " data-backdrop="static" data-keyboard="false" role="dialog">
        <div class="modal-dialog" >
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h3 class="modal-title">PHÂN QUYỀN DÙNG MENU</h3>
                    <h4 class="modal-title">Nhóm quyền: <span id="lbphanquyentitle"></span></h4>
                </div>
                <div id="lbthongbao1" style="color:red;padding:0px  10px;"></div>
                <div class="modal-body" >
                    <div class="box-body">
                        <div class="col-sm-12" style="padding-top:25px;" id="divphanquyen_noidung">
                            <table id="tblphanquyen_noidung" class="table table-bordered table-striped">
                                <thead>
                                    <tr>
                                        <th></th>
                                        <th><input type="checkbox" id="ck_quyen_all" class="checkbox" /></th>
                                        <th style="width:300px;">Menu</th>
                                        <th>Xem</th>
                                        <th>Thêm</th>
                                        <th>Sửa</th>
                                        <th>Xóa</th>
                                        <th>In</th>
                                        <th>Status</th>
                                        <th>Import</th>
                                        <th>Export</th>
                                      
                                    </tr>
                                </thead>
                                <tbody>

                            </table>
                        </div>
                    </div>


                    <div class="modal-footer">
                        <button type="button" class="btn bg-red pull-right" data-dismiss="modal"><i class="fa fa-close"></i>  Đóng</button>
                        <button type="submit" class="btn bg-green pull-left" id="cmdsave_phanquyen"><i class="fa fa-save"></i>&nbsp; Lưu</button>
                    </div>
                </div>
                <!-- /.modal-content -->
            </div>
            <!-- /.modal-dialog -->
        </div>
    </div>

    <style type="text/css">
        .btn_edit{}
        #divphanquyen_noidung{
            max-height:600px;
            overflow:auto;
        }
        .modal-dialog{
              width:800px !important;
            margin:auto;
        }
    </style>

<script>
    js_mn_tt = "@ViewBag.mn_tt";
   // alert(js_mn_tt);
</script>
    <script type="text/javascript">
         

      

        function InitDefault() {
            columnsWidth = [{ sWidth: '5%' }, { sWidth: '5%' }, { sWidth: '40%' }, { sWidth: '10%' }, { sWidth: '10%' }, { sWidth: '10%' }, { sWidth: '10%' }, { sWidth: '10%' }];

            columnAutoWidth = true;
             bLoadDataCommon = false;
             iPrintColStart = 3; // cot bat dau in cua kendouigrid
             iPrintColNumbers = 2; // so cot in

        title = '@Html.Raw(ViewBag.Function_Title)';
        document.title = '@Html.Raw(RICTotal.Models.common.app_title_short)' + " - " + title;
        exportFileName = '@ViewBag.ControllerName';
        myVersion = 2;
        jsonData = []; // chua du lieu can bind ra bang
        bAddEdit = true; // true: add, false: edit
        controllerURL = '/Admin/@ViewBag.ControllerName';
        tblData = '@ViewBag.tblname'; // tên bảng show dữ liệu
        dlgAddEdit = 'dlg@(ViewBag.tblname)'; // dialog chữa form edit
        TienTo = ''; // tên trường tiền tố của 1 bảng
        pageid = 0;

            _row = {
                id: ""
                , name: ""
                , active: 0
            };
        }

        // khoi tao cac gia tri mac dinh khi addnew sau khi reset
        function InitDefaultValue() {
            $('#ckstatus').prop('checked', true);
        }


  function _showGrid() {
        var crudServiceBaseUrl = controllerURL;
        $("#grid_noidung").kendoGrid({
            dataSource: {
                transport: {
                    read: {
                        url: crudServiceBaseUrl + "/GetList/" + js_mn_tt,
                        dataType: "json"
                    }
                },

                 //data: data,
                schema: {
                    parse : function(data) {
                                return data.data;
                        }
                },
                pageSize:100
            },
            filterable: {
               // mode:"row",
                extra: false,
                operators: {
                    string: {
                        contains: "Contains...",
                        startswith: "Starts with",
                        eq: "Is equal to"
                        //, neq: "Is not equal to"
                    }
                }
            },

            // height: 500,
            //toolbar: ["excel"],
            scrollable: false,
            sortable: { mode: "multiple", allowUnsort: true },
            pageable: { input: false, numeric: true },
            reorderable: true,
            resizable: true,
            groupable: true,
            allowCopy: true,
            selectable: "multiple cell",
            excel: {
                fileName: exportFileName + ".xlsx",
                allPages: true,
                filterable: true
            },
            pdf: {
                author: "RIC Total",
                creator: "RIC Total",
                date: new Date(),
                fileName: exportFileName + ".pdf",
                subject: "RIC Total: " + exportFileName,
                title: "RIC Total: " + exportFileName,
                margin: { left: "20pt", right: "20pt", top: "15mm", bottom: "15mm" },
                paperSize: "A4",
                landscape: false,
                scale: 0.8,
                avoidLinks: true,
                repeatHeaders: true,
                template: $("#page-template").html(),
                allPages: true
            },

            columns: [
                {
                    field: "id"
                    , title: "No."
                    , template: "#= ++recordnumber#"
                    , filterable: false   , sortable: false
                },
                {
                    title: "<input type=checkbox id='ckcheckall' onclick='_checkAll();'>"
                    , template: "<input type=checkbox value='#=id#'>"
                    , filterable: false , sortable: false
                }, {
                    title: ""
                     , template: "<a href='javascript://' class='bg-green' title='Thông tin chi tiết => Sửa'  style='padding:5px;' onclick=' _editItem(\"#=id#\",\"#= recordnumber #\")'  data-toggle='modal' data-target='\\#dlg@(ViewBag.tblname)'><i class='fa fa-edit'></a>"
                    , filterable: false  , sortable: false
                },

                { field: "name", title: "Tên nhóm", filterable: { cell: { operator: "contains" } } },
                { field: "active", title: "Status"},
                {
                    title: "", filterable: false, sortable: false
                     , template: "<a data-toggle='modal' data-target='\\#divphanquyen'  onclick='_phanquyen(\"#=id#\",\"#=name#\");'  href='javascript://' class='bg-yellow' title='Phân quyền'  style='padding:5px;'><i class='fa fa-list-ul'></i>  Phân quyền</a>"
                     
                 }
            ],
            dataBound: function (e) {
                recordnumber = 0;
                for (var i = 0; i < this.columns.length; i++) this.autoFitColumn(i);
            }
        }) ;

         grid = $("#grid_noidung").data("kendoGrid");
    }

 

    // khoi tao cac gia tri mac dinh khi addnew sau khi reset
    function InitDefaultValue() {
        $('#txtpagesize').val(@ViewBag.pagesize);
        $('#ckstatus').prop('checked', true);
    }

    function resetAddItem() {

        $('#lbthongbao').html('');
        $('#' + dlgAddEdit + ' input').val('');
        $('#' + dlgAddEdit + ' textarea').val('');
        $('#' + dlgAddEdit + ' input').attr('disabled', false);
    }

 
    function _editItem(obj, rowindex) {
        $('#lbthongbao').html('');
        disableHideObjects();

      var _rowe = grid.dataItem("tbody tr:eq(" + (rowindex - 1) + ")"); //get data

        bAddEdit = false;
        _EDIT_INDEX = rowindex-1;
        _EDIT_ID = _rowe.id;
        
        $('#txtten').val(_rowe.name);
        $('#ckstatus').prop('checked', (_rowe.active / 1 == 1 ? true : false));

        $('#lbthongbao').html('');
 
    }


    function _gridUpdateItem() {
        var grid = $("#grid_noidung").data("kendoGrid");
        var dataSource = grid.dataSource;
        var dataItem = grid.dataItem("tbody tr:eq(" + _EDIT_INDEX + ")"); //get data
        dataItem["name"] = _row.name;
        dataItem["active"] = _row.active;
        grid.refresh();
    }
    //-------------end edit a record

    //------------- valid  a record
   

        $(document).ready(function () {
            $('#cmdsave_phanquyen').click(function () {
                SavePhanQuyen();
            });
            $('#frmdata').validator().on('submit', function (e) {
                if (e.isDefaultPrevented()) {
                } else {

                    return false;
                }
            })
        });

        function disableHideObjects() {
            // $('#txtuid').attr('disabled', true);
        }

        //-------------end edit a record

        //------------- valid  a record
        function IsValid() {

            _row.id = _EDIT_ID;
            _row.name = $("#txtten").val();
            _row.active = ($("#ckstatus").is(':checked') ? 1 : 0);

            // chuan hoa xau
            _row.name = _row.name.replace(reg, '');

            msg = '';

            if (_row.ten == '') msg += '\n- Cần vào Tên menu;';

            if (msg != '') {
                $('#lbthongbao').html('Error: ' + msg);
                return false;
            }

            return true;
        }

       

        function GetRowQuyen(item) {
            var s = '';
            s += '<td style="text-align:left"><input type="checkbox" class="ckrowall"></td>';
            s += '<td style="text-align:left;width:300px;">' + item.ten + '</td>';
            s += '<td><input class="ckxem" type="checkbox" ' + (item.xem == "0" ? "" : "checked") + '></td>';
            s += '<td><input class="ckthem" type="checkbox" ' + (item.them == "0" ? "" : "checked") + '></td>';
            s += '<td><input class="cksua"  type="checkbox" ' + (item.sua == "0" ? "" : "checked") + '></td>';
            s += '<td><input class="ckxoa"  type="checkbox" ' + (item.xoa == "0" ? "" : "checked") + '></td>';
            s += '<td><input class="ckin1"  type="checkbox" ' + (item.in1 == "0" ? "" : "checked") + '></td>';
            s += '<td><input class="ckstatus"  type="checkbox" ' + (item.status == "0" ? "" : "checked") + '></td>';
            s += '<td><input class="ckimport"  type="checkbox" ' + (item.import == "0" ? "" : "checked") + '></td>';
            s += '<td><input class="ckexport"  type="checkbox" ' + (item.export == "0" ? "" : "checked") + '></td>';
          
            return s;
        }

        var tblquyen = 'tblphanquyen_noidung';
        var dataTableQuyen;
        var nhomquyenId = '';
        var jsonDataQuyen = [];

        function _phanquyen(id, vl)
        {
            // phan quyen
            nhomquyenId = id;
           
            $('#lbphanquyentitle').html(vl);

            var h = $(window).height()-240;
            $('#divphanquyen_noidung').css({"max-height": h});
            var url = controllerURL + "/GetPhanquyen/" + js_mn_tt  ;
           
            $.post(url, { data: id }, function (data) {
                jsonDataQuyen = data.data;
                $("#" + tblquyen).dataTable().fnClearTable();
                $("#" + tblquyen).dataTable().fnDestroy();


                //console.log(idName);
                for (var i = 0; i < jsonDataQuyen.length; i++) {
                    var item = jsonDataQuyen[i];
                    var r = "<tr class='odd' role='row'>"
                        + "<td>" + (i + 1) + "</td>"
                        //+ "<td><div><input type='checkbox' class='checkbox' value='" + item["id"] + "' /></div></td>";
                    r += GetRowQuyen(item);
                    r += "</tr>";
                    $("#" + tblquyen).append(r);
                }
             //   dataTableQuyen = $("#" + tblquyen).DataTable({ "bPaginate": false });


                $('.ckrowall').click(function () {
                    var ck = $(this).is(':checked');
                    $(this).closest('tr').find('input:checkbox').attr('checked', ck);
                });


                $('#ck_quyen_all').click(function () {
                    var ck = $(this).is(':checked');
                    $('#' + tblquyen).find('input:checkbox').attr('checked', ck);
                });

            });
        }

        function SavePhanQuyen() {
           
            //if (!IsValid()) return false; // tren view
            var xem = '', i = 0;
            $('#' + tblquyen + ' tbody>tr').each(function () {
                xem += (xem == '' ? '' : ',') + '{"id":"' + jsonDataQuyen[i].id + '"';
                xem += ',"xem":' + ($(this).find('.ckxem').is(':checked') ? 1 : 0) + '';
                xem += ',"them":' + ($(this).find('.ckthem').is(':checked') ? 1 : 0) + '';
                xem += ',"sua":' + ($(this).find('.cksua').is(':checked') ? 1 : 0) + '';
                xem += ',"xoa":' + ($(this).find('.ckxoa').is(':checked') ? 1 : 0) + '';
                xem += ',"in1":' + ($(this).find('.ckin1').is(':checked') ? 1 : 0) + '';
                xem += ',"status":' + ($(this).find('.ckstatus').is(':checked') ? 1 : 0) + '';
                xem += ',"import":' + ($(this).find('.ckimport').is(':checked') ? 1 : 0) + '';
                xem += ',"export":' + ($(this).find('.ckexport').is(':checked') ? 1 : 0) + '';
                xem += ',"phanquyen":' + ($(this).find('.ckexport').is(':checked') ? 1 : 0) + '';
                xem += '}';
                i += 1;
            });
            xem = '[' + xem + ']';
            var data = '{"nhomid":"' + nhomquyenId + '","items":' + xem + '}';
          

            // ---------------------
            var url = controllerURL;

            url += "/SavePhanQuyen/" + js_mn_tt;

            $.post(url, { data: data }, function (data) {
                var dt = data;
                if (dt.code/1 != 100) {
                    $('#lbthongbao1').html(dt.msg);
                    return;
                } else {
                    $('#divphanquyen').modal('hide');
                }
                
            });
            return true;
        }



    </script>
