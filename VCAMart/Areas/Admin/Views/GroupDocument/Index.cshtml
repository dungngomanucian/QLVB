
@{
    ViewBag.Title = "View";
    Layout = "~/Areas/Admin/Views/Shared/main_layout.cshtml";
}

 


<div class="box" style="margin-top: 1px; margin-left:1px;" id="divcontent">
    <div class="box-header">
        <label id="lbcontent_title" style="display:none;">@(ViewBag.Function_Title)</label>
        <a id="cmdadd_cate" class="btn bg-green btn-flat " data-toggle="modal" data-target="#dlg@(ViewBag.tblname)"> <i class="fa fa-plus"></i> &nbsp;Thêm </a>
        <a id="cmddImportJson" class="btn bg-blue-active btn-flat " data-toggle="modal" data-target="#dlgImport">      <i class="fa fa-remove"></i> &nbsp;Import tệp tin json </a>
        <a id="cmddelete_cate" class="btn bg-red btn-flat ">      <i class="fa fa-remove"></i> &nbsp;Xóa </a>

    </div>

    <div class="box-body">
        <div id="grid_noidung"></div>
    </div>
</div>
<form id="frmImportJson">
    <div class="modal fade" id="dlgImport" data-backdrop="static" data-keyboard="false" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h3 class="modal-title">DANH MỤC NHÓM TÀI LIỆU</h3>
                </div>
                <div id="lbthongbao" style="color:red;padding:0px  10px;"></div>
                <div class="modal-body">
                    <div class="box-body">

                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtGroupDocument" class="col-sm-4 control-label">Chọn tệp tin json:</label>
                            <div class="col-sm-8">
                                <table border="0" style="width: 100%; border-collapse: separate; border-spacing: 5px; ">
                                    <tr>
                                        <td style="width:80%"><input id="txtGroupDocument" class="input-control" name="txtGroupDocument" type="text" /></td>
                                        <td style="width:20%"><button id="chonanhbia" class="btn btn-default">  Chọn tệp tin  </button></td>

                                    </tr>
                                    <tr>
                                        <td colspan="2" align="right"><label id="lbltxtGroupDocuments"></label></td>
                                    </tr>

                                </table>
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="chkLoaiHinh" class="col-sm-4 control-label">Thủ tục cá nhân/doanh nghiệp:</label>
                            <div class="col-sm-8">
                                <select id="cbbLoaiHinh" class="form-control" style="width:300px">
                                    <option value="0">Chọn loại thủ tục</option>
                                    <option value="1">Cá nhân</option>
                                    <option value="2">Doanh nghiệp</option>
                                </select>
                            </div>
                        </div>
                    </div>


                    <div class="modal-footer">
                        <button type="button" class="btn bg-red pull-right" data-dismiss="modal"><i class="fa fa-close"></i>  Đóng</button>
                        <button type="button" class="btn bg-green pull-left" id="cmdsave_data"><i class="fa fa-save"></i>&nbsp; Lưu</button>
                    </div>
                </div>
                <!-- /.modal-content -->
            </div>
            <!-- /.modal-dialog -->
        </div>
    </div>
</form>
<form id="frm@(ViewBag.tblname)">
    <div class="modal fade" id="dlg@(ViewBag.tblname)" data-backdrop="static" data-keyboard="false" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h3 class="modal-title">DANH MỤC NHÓM TÀI LIỆU</h3>
                </div>
                <div id="lbthongbao" style="color:red;padding:0px  10px;"></div>
                <div class="modal-body">
                    <div class="box-body">


                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtgroup_code" class="col-sm-4 control-label">Mã nhóm :</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtgroup_code" placeholder="Mã nhóm tài liệu">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtgroup_title" class="col-sm-4 control-label">Tiêu đề :</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtgroup_title" placeholder="Tiêu đề nhóm ">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="txtsource" class="col-sm-4 control-label">Nguồn trích dẫn :</label>
                            <div class="col-sm-8">
                                <input type="text" class="form-control" id="txtsource" placeholder="Nguồn trích dẫn ">
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="cbbgroup_type" class="col-sm-4 control-label">Cá nhân/doanh nghiệp:</label>
                            <div class="col-sm-8">
                                <select id="cbbgroup_type" class="form-control" style="width:350px">
                                    <option value="0">Chọn loại thủ tục</option>
                                    <option value="1">Cá nhân</option>
                                    <option value="2">Doanh nghiệp</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group" style="padding-top:25px;">
                            <label for="chkCV_Status" class="col-sm-4 control-label">Trạng thái :</label>
                            <div class="col-sm-8">
                                <input type="checkbox" id="ckstatus" />
                            </div>
                        </div>


                    </div>


                    <div class="modal-footer">
                        <button type="button" class="btn bg-red pull-right" data-dismiss="modal"><i class="fa fa-close"></i>  Đóng</button>
                        <button type="button" class="btn bg-green pull-left" id="cmdsave_cate"><i class="fa fa-save"></i>&nbsp; Lưu</button>
                    </div>
                </div>
                <!-- /.modal-content -->
            </div>
            <!-- /.modal-dialog -->
        </div>
    </div>
    <!-- /.modal -->
</form>

<div id="dialog">
</div>
