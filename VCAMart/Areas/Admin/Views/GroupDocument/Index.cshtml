<script>
    $(function () {
        $("#chonanhbia").click(function () {
            var finder = new CKFinder();
            finder.selectActionFunction = function (fileUrl) {
                $("#txtGroupDocument").val(fileUrl);
            };
            finder.popup();
        });
    });
</script>
<script type="text/javascript">


    function InitDefault() {
          iPrintColStart = 3; // cot bat dau in cua kendouigrid
          iPrintColNumbers = 3; // so cot in

          columnsWidth = [{ sWidth: '10%' }, { sWidth: '30%' }, { sWidth: '30%' },{ sWidth: '30%' }];
        columnAutoWidth = false;
        bLoadDataCommon = false;
        title = '@Html.Raw(ViewBag.Function_Title)';
        document.title = '@Html.Raw(RICTotalAdmin.Models.common.app_title_short)' + " - " + title;
        exportFileName = '@ViewBag.ControllerName';

        myVersion = 2;
          jsonData= []; // chua du lieu can bind ra bang
          urlobj;
          bAddEdit = true; // true: add, false: edit

        controllerURL = '/@ViewBag.ControllerName';
        tblData = '@ViewBag.tblname'; // tên bảng show dữ liệu
        dlgAddEdit = 'dlg@(ViewBag.tblname)'; // dialog chữa form edit
        TienTo = 'CQBH'; // tên trường tiền tố của 1 bảng
        var userID  ='@ViewBag.login_nv_id.ToString()';
          _row = {
              id: ""
             , Odl_Code:""
              , group_code: ""

              , group_title: ""
              , source:""
              , active: ""
              , group_type:""
              , jsonFile: ""
              , LoaiHinh:""
              , CreatedById:userID
          };
    }

    // khoi tao cac gia tri mac dinh khi addnew sau khi reset
    function InitDefaultValue() {
        //$('#txtpagesize').val(10);
       // $('#ckmultilogin').prop('checked', true);
       // $('#ckstatus').prop('checked', true);


         $('#txtpagesize').val(@ViewBag.pagesize);
        //$('#ckstatus').prop('checked', true);
    }



    $(document).ready(function () {
        js_mn_tt = "@ViewBag.mn_tt";
       // loadComboNhom('cbbCV_CQL_Id', '/ChucVu/GetParent/' + 'js_mn_tt','id','ten',"");
      //  $('#cbbCV_CQL_Id').select2();

        $('#cmdsave_data').click(function () {
            _saveData();
        });

        $('#frmuser').validator().on('submit', function (e) {
            if (e.isDefaultPrevented()) {
            } else {
                // everything looks good!

                return false;
            }
        })

    });

   function _saveData() {

     var url = controllerURL + "/ImportJsonToDatabase/1";
    _row.jsonFile = $('#txtGroupDocument').val();
    _row.LoaiHinh = $('#cbbLoaiHinh').val();
    if (_row.LoaiHinh == 0) {
        // 2. Đóng modal đúng cách

        $('#dlgImport').modal('hide');

        myalert("Bạn phải chọn loại thủ tục", 500);
        return false;

    }
    $.post(url, { data: JSON.stringify(_row) }, function (data) {

            var dt = data;
            if (dt.code / 1 != 100) {

                meAlert("Thông báo", dt.msg, 500);
                return false;
        }
        myalert("Cập nhật thành công", 500);

        $('#dlgImport').modal('hide');
        _showGrid();

        });

        return true; // de ko submit len may chu
    }

    function disableHideObjects()
    {
       // $('#txtuid').attr('disabled', true);
    }

    function resetAddItem() {
       // $('#cbbnhomquyen').val([]);
      //  $("#cbbnhomquyen").trigger("change");

        $('#' + dlgAddEdit + ' input').val('');
        $('#' + dlgAddEdit + ' textarea').val('');
        $('#' + dlgAddEdit + ' input').attr('disabled', false);
    }
   // load du lieu ra form de sua
    function _editItem(obj, rowindex) {
        $('#lbthongbao').html('');

        // $('#txtma').prop('readonly', true);
       // disableHideObjects();
        bAddEdit = false;
       // var row = jsonData[rowindex];
        var row = grid.dataItem("tbody tr:eq(" + (rowindex - 1) + ")"); //get data


        bAddEdit = false;
        _EDIT_INDEX = rowindex-1;
        _EDIT_ID = row.id;
        _COMMONCODE = row.group_code;

        $('#txtgroup_code').val(row.group_code);
        $('#txtgroup_title').val(row.group_title);
        $('#txtsource').val(row.source);
        $('#cbbgroup_type').val(row.group_type)
        $('#ckstatus').prop('checked', (row.active / 1 == 1 ? true : false));
        $("#cbbgroup_type").trigger("change");


    }



    //-------------end edit a record

    //------------- valid  a record
    function IsValid() {

        _row.id = _EDIT_ID;
        _row.Odl_Code = _COMMONCODE;

        _row.group_code = $('#txtgroup_code').val();
        _row.group_title = $('#txtgroup_title').val();
        _row.source = $('#txtsource').val();
        _row.group_type = $('#cbbgroup_type').val()
        _row.active = ($("#ckstatus").is(':checked') ? 1 : 0);

        msg="";

        if (_row.group_code =="")
            msg+="<br>+ Chưa nhập mã.";
        if (_row.group_title =="")
            msg+="<br>+ Chưa nhập tên.";



        if (bAddEdit)
        {
            //if (_row.pwd == '') msg += '\n- Cần vào Mật khẩu;';
            //if (_row.pwd1 == '') msg += '\n- Cần vào Mật khẩu xác nhận;';
        }

        if (msg != '') {
            DisplayDialog('dialog','cmdsave_cate',msg);
            return false;
        }

        return true;
    }
    //------------- end valid a record
    function _getGroupName(obj)
    {
        var s = '';
        for (i = 0; i < obj.length; i++)
        {
            s += '<span class="groupname" >' + obj[i] + '</span>';
        }
        return s;
    }

    function _showGrid() {

        var crudServiceBaseUrl = controllerURL ;

        $("#grid_noidung").kendoGrid({
            dataSource: {
                transport: {
                    read: {
                        url: crudServiceBaseUrl + "/GetList/" + "@ViewBag.mn_tt",
                        dataType: "json"
                    }
                },

                //data: data,
                schema: {
                    parse : function(data) {
                                return data.data;
                        }
                },
                pageSize: @ViewBag.pagesize
            },
            filterable: {
               // mode:"row",
                extra: false,
                operators: {
                    string: {
                        contains: "Contains...",
                        startswith: "Starts with",
                        eq: "Is equal to"
                        //, neq: "Is not equal to"
                    }
                }
            },

            // height: 500,
            //toolbar: ["excel"],
            scrollable: false,
            sortable: { mode: "multiple", allowUnsort: true },
            pageable: { input: false, numeric: true },
            reorderable: true,
            resizable: true,
            groupable: true,
            allowCopy: true,
            selectable: "multiple cell",
            excel: {
                fileName: exportFileName + ".xlsx",
                allPages: true,
                filterable: true
            },
            pdf: {
                author: "RIC Total",
                creator: "RIC Total",
                date: new Date(),
                fileName: exportFileName + ".pdf",
                subject: "RIC Total: " + exportFileName,
                title: "RIC Total: " + exportFileName,
                margin: { left: "20pt", right: "20pt", top: "15mm", bottom: "15mm" },
                paperSize: "A4",
                landscape: true,
                scale: 0.8,
                avoidLinks: true,
                repeatHeaders: true,
                template: $("#page-template").html(),
                allPages: true
            },

            columns: [
                {field: "id", title: "No.", template: "#= ++recordnumber#", filterable: false   , sortable: false},
                {
                    title: "<input type=checkbox id='ckcheckall' onclick='_checkAll();'>"
                    , template: "<input type=checkbox value='#=id#'>"               , filterable: false , sortable: false
                }, {
                    title: ""
                    , template: "<a href='javascript://' class='bg-green' title='Thông tin chi tiết => Sửa'  style='padding:5px;' onclick=' _editItem(\"#=id#\",\"#= recordnumber #\")'  data-toggle='modal' data-target='\\#dlg@(ViewBag.tblname)'><i class='fa fa-edit'></a>"
                    , filterable: false  , sortable: false
                },

                { field: "group_code", title: "Mã nhóm", filterable: { cell: { operator: "contains" } } },
                { field: "group_title", title: "Tiêu đề nhóm", filterable: { cell: { operator: "contains" } } },
                { field: "TrangThai", title: "Trạng thái", filterable: { cell: { operator: "contains" } } },



       ],
            dataBound: function (e) {
                recordnumber = 0;
                for (var i = 0; i < this.columns.length; i++) this.autoFitColumn(i);
            }
        }) ;

         grid = $("#grid_noidung").data("kendoGrid");
    }




    function _gridUpdateItem() {

        var grid = $("#grid_noidung").data("kendoGrid");
        var dataSource = grid.dataSource;
        var dataItem = grid.dataItem("tbody tr:eq(" + _EDIT_INDEX + ")"); //get data
        dataItem["group_code"] = _row.group_code;
        dataItem["group_title"] = _row.group_title;

        dataItem["active"] = _row.active;

       // dataItem["active"] = _row.active;

        grid.refresh();
    }
    //-------------end edit a record


</script>
