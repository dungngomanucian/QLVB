    function _getGroupName(obj)
    {
        var s = '';
        for (i = 0; i < obj.length; i++)
        {
            s += '<span class="groupname" >' + obj[i] + '</span>';
        }
        return s;
    }

    function _showGrid() {
        var crudServiceBaseUrl = controllerURL;

        $("#grid_noidung").kendoGrid({
            dataSource: {
                transport: {
                    read: {
                        url: crudServiceBaseUrl + "/GetList/" + js_mn_tt,
                        dataType: "json",
                        method: "POST"
                    }
                },
                schema: {
                    parse: function (data) {
                        if (typeof data.data === "string") {
                            data.data = JSON.parse(data.data);
                        }

                        if (data.data) {
                            for (var i = 0; i < data.data.length; i++)
                                data.data[i].active = data.data[i].is_active;
                        }
                        return data;
                    },
                    data: function (data) {
                        return data.data;
                    },
                    total: function (data) {
                        return data.total;
                    },
                    model: {
                        fields: {
                            id: { type: "string" },
                            doc_code: { type: "string" },
                            doc_title: { type: "string" },
                            issuing_authority: { type: "string" },
                            effective_date: { type: "date" },
                            active: { type: "number" }
                        }
                    }
                },
                pageSize: @ViewBag.pagesize,
                serverPaging: true
            },
            filterable: {
                extra: false,
                operators: {
                    string: {
                        contains: "Contains...",
                        startswith: "Starts with",
                        eq: "Is equal to"
                    }
                }
            },
            scrollable: false,
            sortable: { mode: "multiple", allowUnsort: true },
            pageable: true,
            reorderable: true,
            resizable: true,
            groupable: true,
            allowCopy: true,
            selectable: "multiple cell",
            excel: {
                fileName: exportFileName + ".xlsx",
                allPages: true,
                filterable: true
            },
            pdf: {
                author: "RIC Total",
                creator: "RIC Total",
                date: new Date(),
                fileName: exportFileName + ".pdf",
                subject: "RIC Total: " + exportFileName,
                title: "RIC Total: " + exportFileName,
                margin: { left: "20pt", right: "20pt", top: "15mm", bottom: "15mm" },
                paperSize: "A4",
                landscape: true,
                scale: 0.8,
                avoidLinks: true,
                repeatHeaders: true,
                template: $("#page-template").html(),
                allPages: true
            },
            columns: [
                {
                    field: "id", title: "STT", template: "#= ++recordnumber#", width: 50,
                    headerAttributes: { style: "text-align:center;" }, attributes: { style: "text-align:center;" }
                },
                {
                    title: "<input type=checkbox id='ckcheckall' onclick='_checkAll();'>",
                    template: "<input type=checkbox value='#=id#'>", width: 40,
                    headerAttributes: { style: "text-align:center;" }, attributes: { style: "text-align:center;" }
                },
                {
                    title: "Tác vụ",
                    template: "<a href='javascript://' class='btn btn-xs btn-success' title='Sửa' onclick='_editItem(\"#=uid#\", \"#=recordnumber#\")' data-toggle='modal' data-target='\\#dlg@(ViewBag.tblname)'><i class='fa fa-edit'></i></a>",
                    width: 60, headerAttributes: { style: "text-align:center;" }, attributes: { style: "text-align:center;" }
                },

                { field: "doc_code", title: "Mã VB", width: 120, filterable: { cell: { operator: "contains" } } },

                { field: "doc_title", title: "Tên tài liệu / Trích yếu", filterable: { cell: { operator: "contains" } } },

                { field: "issuing_authority", title: "Cơ quan BH", width: 150, filterable: { cell: { operator: "contains" } } },

                {
                    field: "effective_date", title: "Ngày hiệu lực", width: 120,
                    template: "#= effective_date ? kendo.toString(kendo.parseDate(effective_date), 'dd/MM/yyyy') : '' #",
                    headerAttributes: { style: "text-align:center;" }, attributes: { style: "text-align:center;" }
                },

                {
                    field: "active", title: "Trạng thái", width: 120,
                    template: "#= active == 1 ? '<span class=\"label label-primary\">Hiển thị</span>' : '<span class=\"label label-default\">Ẩn</span>' #",
                    headerAttributes: { style: "text-align:center;" }, attributes: { style: "text-align:center;" }
                }
            ],
            dataBound: function (e) {
                var grid = this;
                var dataSource = grid.dataSource;
                recordnumber = (dataSource.page() - 1) * dataSource.pageSize();
                for (var i = 0; i < this.columns.length; i++) this.autoFitColumn(i);
            }
        });

        grid = $("#grid_noidung").data("kendoGrid");
    }




    function _gridUpdateItem() {

        var grid = $("#grid_noidung").data("kendoGrid");
        var dataSource = grid.dataSource;
        var dataItem = grid.dataItem("tbody tr:eq(" + _EDIT_INDEX + ")"); //get data
        dataItem.set("doc_code", _row.doc_code);
        dataItem.set("doc_title", _row.doc_title);
        dataItem.set("issuing_authority", _row.issuing_authority);
        dataItem.set("active", _row.active);

        // Cập nhật ngày tháng (phải parse về Date object thì Grid mới hiểu)
        if (_row.effective_date) {
            dataItem.set("effective_date", kendo.parseDate(_row.effective_date, "yyyy-MM-dd"));
        } else {
            dataItem.set("effective_date", null);
        }

       // dataItem["active"] = _row.active;

        grid.refresh();
    }
    //-------------end edit a record


</script>