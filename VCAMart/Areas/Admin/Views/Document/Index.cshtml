        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h3 class="modal-title">DANH MỤC TÀI LIỆU</h3>
                </div>

                <div id="lbthongbao" style="color:red; padding:0px 10px; font-weight:bold;"></div>

                <div class="modal-body">
                    <div class="box-body">

                        
                        <div class="form-group row" style="margin-bottom:15px;">
                            <label class="col-sm-3 control-label">Mã tài liệu <span style="color:red">(*)</span>:</label>
                            <div class="col-sm-9">
                                <select id="cbbgroup_id" class="form-control" style="width:100%;"></select>
                            </div>
                        </div>
                        <div class="form-group row" style="margin-bottom:15px;">
                            <label class="col-sm-3 control-label">Mã tài liệu <span style="color:red">(*)</span>:</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="txtdoc_code" placeholder="Ví dụ: NQ-01/2026">
                            </div>
                        </div>

                       

                        <div class="form-group row" style="margin-bottom:15px;">
                            <label class="col-sm-3 control-label">Tên/Trích yếu <span style="color:red">(*)</span>:</label>
