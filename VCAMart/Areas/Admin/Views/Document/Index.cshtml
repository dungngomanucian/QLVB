    function loadCategoryTree() {
        $.getJSON(controllerURL + '/GetCategoryTree/1', function (data) {

            let html = '';
            let currentGroup = '';

            $.each(data, function (i, item) {

                // Group mới
                if (currentGroup !== item.group_code) {
                    if (currentGroup !== '') {
                        html += '</optgroup>';
                    }
                    html += `<optgroup label="📁 ${item.group_title}">`;
                    currentGroup = item.group_code;
                }

                // Category
                if (item.category_code) {
                    html += `
                    <option value="${item.category_code}">
                        └─ ${item.category_title}
                    </option>`;
                }
            });

            if (currentGroup !== '') {
                html += '</optgroup>';
            }

            $('#cbbgroup_id').html(html);
        });
    }

    function loadLawDropdowns(prefix, groupSelectId, categorySelectId) {
        // Thêm "/1" để buộc route MVC dùng pattern {controller}/{action}/{id}
        $.getJSON(controllerURL + '/GetLawGroups/1', { prefix: prefix })
            .done(function (data) {
                var $g = $('#' + groupSelectId);
                $g.empty();
                $g.append('<option value="">-- Chọn --</option>');

                if (!data || !data.length) {
                    $g.append('<option value="">(Không có dữ liệu)</option>');
                    return;
                }

                $.each(data, function (i, item) {
                    $g.append('<option value="' + item.group_code + '">' + item.group_title + '</option>');
                });
            })
            .fail(function (xhr) {
                $('#lbthongbao_pdf').html('Không tải được danh sách Luật/Bộ luật (HTTP ' + xhr.status + ').');
            });

        $('#' + groupSelectId).on('change', function () {
            var code = $(this).val();
            var $c = $('#' + categorySelectId);
            $c.empty();
            if (!code) {
                $c.append('<option value="">-- Chọn nhóm --</option>');
                return;
            }

            $.getJSON(controllerURL + '/GetLawCategories/1', { groupCode: code, prefix: prefix })
                .done(function (data) {
                    $c.append('<option value="">-- Chọn nhóm --</option>');

                    if (!data || !data.length) {
                        $c.append('<option value="">(Không có dữ liệu)</option>');
                        return;
                    }

                    $.each(data, function (i, item) {
                        $c.append('<option value="' + item.category_code + '">' + item.category_title + '</option>');
                    });
                })
                .fail(function (xhr) {
                    $('#lbthongbao_pdf').html('Không tải được danh sách Nhóm (HTTP ' + xhr.status + ').');
                });
        });
    }

    function initPdfUploadUi() {
        var selectedFile = null;

        function resetUi() {
            selectedFile = null;
            $('#pdfSelectedInfo').html('');
            $('#lbthongbao_pdf').html('');
            $('#cmdUploadPdfDo').prop('disabled', true);
            $('#pdfUploadProgressWrap').hide();
            $('#pdfUploadProgress').css('width', '0%').text('0%');
        }

        function setSelected(file) {
            selectedFile = file;
            if (!selectedFile) {
                resetUi();
                return;
            }
            var ext = (selectedFile.name || '').toLowerCase().split('.').pop();
            if (ext !== 'pdf') {
                selectedFile = null;
                $('#lbthongbao_pdf').html('Chỉ hỗ trợ tệp PDF (*.pdf).');
                $('#cmdUploadPdfDo').prop('disabled', true);
                $('#pdfSelectedInfo').html('');
                return;
            }
            var sizeMb = (selectedFile.size / (1024 * 1024)).toFixed(2);
            $('#pdfSelectedInfo').html('<b>Đã chọn:</b> ' + selectedFile.name + ' <span style="color:#666">(' + sizeMb + ' MB)</span>');
            $('#cmdUploadPdfDo').prop('disabled', false);
        }

        $('#dlgUploadPdf').on('show.bs.modal', function () {
            resetUi();
        });

        $('#pdfDropzone').on('click', function () {
            $('#pdfFileInput').val('');
            $('#pdfFileInput').click();
        });

        $('#pdfFileInput').on('change', function (e) {
            var f = (e.target.files && e.target.files.length > 0) ? e.target.files[0] : null;
            setSelected(f);
        });

        $('#pdfDropzone').on('dragover', function (e) {
            e.preventDefault();
            e.stopPropagation();
            $(this).css('border-color', '#3c8dbc');
        });
        $('#pdfDropzone').on('dragleave', function (e) {
            e.preventDefault();
            e.stopPropagation();
            $(this).css('border-color', '#9aa0a6');
        });
        $('#pdfDropzone').on('drop', function (e) {
            e.preventDefault();
            e.stopPropagation();
            $(this).css('border-color', '#9aa0a6');
            var dt = e.originalEvent.dataTransfer;
            var f = (dt && dt.files && dt.files.length > 0) ? dt.files[0] : null;
            setSelected(f);
        });

        $('#cmdUploadPdfDo').on('click', function () {
            if (!selectedFile) return;

            var groupCode = $('#cbbLawGroup').val();
            var categoryCode = $('#cbbLawCategory').val();
            if (!groupCode || !categoryCode) {
                $('#lbthongbao_pdf').html('Vui lòng chọn đầy đủ Luật/Bộ luật và Nhóm (Dân sự, Hình sự, ...).');
                return;
            }

            var formData = new FormData();
            formData.append('file', selectedFile);
            formData.append('groupCode', groupCode);
            formData.append('categoryCode', categoryCode);

            $('#lbthongbao_pdf').html('');
            $('#cmdUploadPdfDo').prop('disabled', true);
            $('#pdfUploadProgressWrap').show();

            $.ajax({
                url: controllerURL + '/UploadPdf/1',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                xhr: function () {
                    var xhr = new window.XMLHttpRequest();
                    xhr.upload.addEventListener('progress', function (evt) {
                        if (evt.lengthComputable) {
                            var p = Math.round((evt.loaded / evt.total) * 100);
                            $('#pdfUploadProgress').css('width', p + '%').text(p + '%');
                        }
                    }, false);
                    return xhr;
                },
                success: function (res) {
                    if (!res || res.code / 1 !== 100) {
                        $('#lbthongbao_pdf').html((res && res.msg) ? res.msg : 'Upload thất bại.');
                        $('#cmdUploadPdfDo').prop('disabled', false);
                        return;
                    }

                    // Auto fill vào trường "Nguồn" của form thêm/sửa (nếu user muốn đính kèm)
                    if (res.data && res.data.fileUrl) {
                        $('#txtsource_url').val(res.data.fileUrl);
                    }

                    myalert("Tải PDF thành công", 500);
                    $('#dlgUploadPdf').modal('hide');
                },
                error: function (xhr) {
                    $('#lbthongbao_pdf').html('Upload thất bại. ' + (xhr && xhr.status ? ('(HTTP ' + xhr.status + ')') : ''));
                    $('#cmdUploadPdfDo').prop('disabled', false);
                }
            });
        });
    }


