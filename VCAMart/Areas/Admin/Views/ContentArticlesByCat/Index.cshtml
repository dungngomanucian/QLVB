    function IsValid() {

        _row.id = _EDIT_ID;
        _row.CC_Id = _EDIT_ID;

        _row.CA_CC_Id = $('#cbbCA_CC_Id').val();
        _row.CA_Title = $('#txtCA_Title').val();
        _row.CA_SubTitle = $('#txtCA_SubTitle').val();
        _row.CA_FriendlyUrl = $('#txtCA_FriendlyUrl').val();
        _row.CA_CapHoc = $('#cbbCA_CapHoc').val();

        var objEditor1 = CKEDITOR.instances["txtCA_Introduction"];
        var objEditor2 = CKEDITOR.instances["txtCA_ContentBody"];


