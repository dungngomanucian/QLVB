        _row.noidung= CKEDITOR.instances.txtCA_Introduction.document.getBody().getText();


        str = $("#txtCA_ThumbnailPath").val();

        if (!str.includes("https://"))
            _row.CA_ThumbnailPath = path + $("#txtCA_ThumbnailPath").val();
        else
            _row.CA_ThumbnailPath = $("#txtCA_ThumbnailPath").val();

        var strCA_FilePdf  = $("#txtCA_FilePdf").val();
        if (!strCA_FilePdf.includes("https://"))
            _row.CA_FilePdf = path + $("#txtCA_FilePdf").val();
        else
            _row.CA_FilePdf = $("#txtCA_FilePdf").val();


        if ($('#chkCA_Published').is(':checked'))
            _row.CA_Published = 1;
        else
            _row.CA_Published = 0;
        if ($('#chkCA_AllowComment').is(':checked'))
            _row.CA_AllowComment = 1;
        else
            _row.CA_AllowComment = 0;

        if ($('#chkCA_IsHot').is(':checked'))
            _row.CA_IsHot = 1;
        else
            _row.CA_IsHot = 0;

        if ($('#chkCA_ShowDate').is(':checked'))
            _row.CA_ShowDate = 1;
        else
            _row.CA_ShowDate = 0;

        _row.CA_DisplayOnApp = ($("#chkCA_DisplayOnApp").is(':checked') ? 1 : 0);

        var  strDate = new Date($('#txtCA_CreatedDate').val());
        var thoigian = strDate.getFullYear() + "-" + (strDate.getMonth() + 1) + "-" + strDate.getDate();
        var h = strDate.getHours();
        var m = strDate.getMinutes();
        var s = strDate.getSeconds();
        var gio = h + ":" + m + ":" + s;
        thoigian+=" " + gio;

        _row.CA_CreatedDate =thoigian;


        _row.CA_PageTitle = $('#txtCA_PageTitle').val();
        _row.CA_MetaKeyword = $('#txtCA_MetaKeyword').val();
        _row.CA_MetaDescription = $('#txtCA_MetaDescription').val();
        _row.CA_Notes = $('#txtCA_Notes').val();


        msg = '';
        if(_row.CA_CC_Id=='00000000-0000-0000-0000-000000000000')
            msg+='\n+ Chưa chọn chủ đề tin tức';
        if (_row.CA_Title == '')
            msg += '\n+ Tiêu đề tin tức không được để trống';


        if (msg != '') {
           $('#lbthongbao').html('Error: ' + msg);
            return false;
        }

        return true;
    }
