                                                <option value="1">--Cấp tiểu học</option>
                                                <option value="2">--Cấp THCS</option>
                                                <option value="3">--Cấp THPT</option>
                                            </select>
                                        </td>
                                        <td>Ngày cập nhật:</td>
                                        <td>
                                            <input type="datetime-local" step="1" id="txtCA_CreatedDate" class="input-control" style="width: 100%" placeholder="dd/mm/yyyy">
                                        </td>
                                    </tr>
                                </table>
                            </td>
                            
                        </tr>
                        <tr>
                            <td>
                                Tiêu đề:
                            </td>
                            <td>
                                <input type="text" class="form-control" id="txtCA_Title" placeholder="">
                            </td>
                        </tr>
                        <tr>
                            <td>
                                Tiêu đề phụ:
                            </td>
                            <td>
                                <input type="text" class="form-control" id="txtCA_SubTitle" placeholder="">
                            </td>
                        </tr>
                        <tr>
                            <td>Địa chỉ URL:</td>
                            <td><input type="text" class="form-control" id="txtCA_FriendlyUrl" placeholder=""> </td>
                        </tr>
                        <tr>
                            <td>Nội dung tóm tắt:</td>
                            <td><textarea id="txtCA_Introduction" cols="20" rows="2"></textarea> </td>
                        </tr>
                        <tr>
                            <td>Nội dung:</td>
                            <td>
                                <textarea id="txtCA_ContentBody" cols="20" rows="2"></textarea>
                            </td>
                        </tr>
                        <tr>
                            <td>Tác giả:</td>
                            <td><input type="text" class="form-control" id="txtCA_Author" placeholder=""> </td>
                        </tr>
                        <tr>
                            <td>Ảnh đại diện:</td>
                            <td>
                                <table border="0" style="width:100%">
                                    <tr>
                                        <td><input id="txtCA_ThumbnailPath" class="input-control" name="txtCC_Image" type="text" /></td>
                                        <td><button id="chonanhbia" class="btn btn-default">  Chọn tệp tin  </button></td>
                                    </tr>
                                </table>                                  
                               
                            </td>
                        </tr>                     
                        <tr>
                            <td>Thông tin chung:</td>
                            <td>
                                Xuất bản: <input type="checkbox" id="chkCA_Published" style="vertical-align:auto" />
                                Cho phép comment: <input type="checkbox" id="chkCA_AllowComment" />
                                Là bài viết hot: <input type="checkbox" id="chkCA_IsHot"  />
                                Hiển thị ngày đăng: <input type="checkbox" id="chkCA_ShowDate" />
                                Video/Audio: <input type="checkbox" id="chkCA_DisplayOnApp" />
                            </td>
                        </tr>
                        <tr>
                            <td>Tiêu đề trang:</td>
                            <td><input type="text" class="form-control" id="txtCA_PageTitle" placeholder=""> </td>
                        </tr>
                        <tr>
                            <td>Từ khóa:</td>
                            <td><input type="text" class="form-control" id="txtCA_MetaKeyword" placeholder=""> </td>
                        </tr>
                        <tr>
                            <td>Từ khóa mô tả:</td>
                            <td><input type="text" class="form-control" id="txtCA_MetaDescription" placeholder=""> </td>
                        </tr>
                        <tr>
                            <td>Ghi chú:</td>
                            <td><input type="text" class="form-control" id="txtCA_Notes" placeholder=""> </td>
                        </tr>
                        <tr>
                            <td>Tệp Pdf:</td>
                            <td>
                                <table border="0" style="width:100%">
                                    <tr>
                                        <td><input id="txtCA_FilePdf" class="input-control" name="txtCA_FilePdf" type="text" /></td>
                                        <td><button id="chonanhbia1" class="btn btn-default">  Chọn tệp tin  </button></td>
                                    </tr>
                                </table>

                            </td>
                        </tr>           
                    </table>    
                
                      
                </div>


                 <div class="modal-footer">
                        <button type="button" class="btn bg-red pull-right" data-dismiss="modal"><i class="fa fa-close"></i>  Đóng</button>
                        <button type="button" class="btn bg-green pull-left" id="cmdsave_cate"><i class="fa fa-save"></i>&nbsp; Lưu</button>
                    </div>
            </div>
            <!-- /.modal-content -->
        </div>
        <!-- /.modal-dialog -->
    </div>
        </div>
    <!-- /.modal -->
</form>
 

