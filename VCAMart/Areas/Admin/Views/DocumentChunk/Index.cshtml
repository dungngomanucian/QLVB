
@{
    ViewBag.Title = "View";
    Layout = "~/Areas/Admin/Views/Shared/main_layout.cshtml";
    int totalNotChunk =(int)ViewBag.TotalNotChunk;
}




<div class="box" style="margin-top: 1px; margin-left:1px;" id="divcontent">
    <div class="box-header">
        <table border="0" style="width:100%">
            <tr>
                <td style="width:25%">
                    <label id="lbcontent_title" style="display:none;">@(ViewBag.Function_Title)</label>
                    <a id="cmdchunk" class="btn bg-green btn-flat "> <i class="fa fa-plus"></i> &nbsp;Tạo chunk cho tài liệu </a>

                    <a id="cmddelete_cate" class="btn bg-red btn-flat "><i class="fa fa-remove"></i> &nbsp;Xóa </a>
                   
                </td>
                <td>
                   Số tài liệu cần xử lý: <input type="text" name="txtnumDocument" id="txtnumDocument" value="20" size="10" /> 
                </td>
                <td align="right" style="color:blue; font-weight:bold" >Tổng số tài liệu chưa xử lý: 
                    <span id="txtDocumentNotChunk"></span>
                </td>
            </tr>
        </table>
       
    </div>

    <div class="box-body">
        <div id="grid_noidung"></div>
    </div>
</div>
 
<div id="dialog">
</div>
<style type="text/css">
    .btn_edit {
    }
</style>
 
<script type="text/javascript">


    function InitDefault() {
          iPrintColStart = 3; // cot bat dau in cua kendouigrid
          iPrintColNumbers = 3; // so cot in

          columnsWidth = [{ sWidth: '10%' }, { sWidth: '30%' }, { sWidth: '30%' },{ sWidth: '30%' }];
        columnAutoWidth = false;
        bLoadDataCommon = false;
        title = '@Html.Raw(ViewBag.Function_Title)';
        document.title = '@Html.Raw(RICTotalAdmin.Models.common.app_title_short)' + " - " + title;
        exportFileName = '@ViewBag.ControllerName';

        myVersion = 2;
          jsonData= []; // chua du lieu can bind ra bang
          urlobj;
          bAddEdit = true; // true: add, false: edit

        controllerURL = '/@ViewBag.ControllerName';
        tblData = '@ViewBag.tblname'; // tên bảng show dữ liệu
        dlgAddEdit = 'dlg@(ViewBag.tblname)'; // dialog chữa form edit
        TienTo = 'CQBH'; // tên trường tiền tố của 1 bảng
        var userID  ='@ViewBag.login_nv_id.ToString()';
          _row = {
              id: ""
             , Odl_Code:""
              , doc_Id: ""

              , doc_code: ""
              , doc_title:""
              , active: ""
              , jsonFile: ""
              , numDocument:""
              , CV_CreatedById:userID
          };
    }

    // khoi tao cac gia tri mac dinh khi addnew sau khi reset
    function InitDefaultValue() {

         $('#txtpagesize').val(@ViewBag.pagesize);
        //$('#ckstatus').prop('checked', true);
    }



    $(document).ready(function () {
        js_mn_tt = "@ViewBag.mn_tt";
        $('#txtDocumentNotChunk').html('@totalNotChunk');
        $('#cmdchunk').click(function () {
            _saveData();
        });
        $('#frmuser').validator().on('submit', function (e) {
            if (e.isDefaultPrevented()) {
            } else {
                // everything looks good!

                return false;
            }
        })

    });

    function _saveData() {

        var url = controllerURL + "/RunChunkBatch/1";
        _row.numDocument = $('#txtnumDocument').val();
        $.post(url, { data: JSON.stringify(_row) }, function (data) {

            var dt = data;
            if (dt.code / 1 != 100) {

                meAlert("Thông báo", dt.msg, 500);
                return false;
            }
            $('#txtDocumentNotChunk').html(dt.total_not_chunked);
            myalert("Đã xử lý " + dt.processed +
                " tài liệu. Còn lại " + dt.total_not_chunked +
                " tài liệu chưa xử lý.", 500);
            _showGrid();

        });

        return true; // de ko submit len may chu
    }

    function disableHideObjects()
    {
       // $('#txtuid').attr('disabled', true);
    }

    function resetAddItem() {
       // $('#cbbnhomquyen').val([]);
      //  $("#cbbnhomquyen").trigger("change");

        $('#' + dlgAddEdit + ' input').val('');
        $('#' + dlgAddEdit + ' textarea').val('');
        $('#' + dlgAddEdit + ' input').attr('disabled', false);
    }
   // load du lieu ra form de sua
    function _editItem(obj, rowindex) {
        $('#lbthongbao').html('');

        // $('#txtma').prop('readonly', true);
       // disableHideObjects();
        bAddEdit = false;
       // var row = jsonData[rowindex];
        var row = grid.dataItem("tbody tr:eq(" + (rowindex - 1) + ")"); //get data


        bAddEdit = false;
        _EDIT_INDEX = rowindex-1;
        _EDIT_ID = row.id;
        _COMMONCODE = row.category_code;

        $('#txtcategory_code').val(row.category_code);
        $('#txtCV_Name').val(row.category_title);


        $('#ckstatus').prop('checked', (row.active / 1 == 1 ? true : false));

       // $('#cbbCV_CQL_Id').val(row.CV_CQL_Id);
       // $("#cbbCV_CQL_Id").trigger("change");

