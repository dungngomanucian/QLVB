    //-------------end edit a record

    //------------- valid  a record
    function IsValid() {

        _row.id = _EDIT_ID;
        _row.Odl_Code = _COMMONCODE;
        _row.category_code = $('#txtcategory_code').val();
        _row.CV_Name =$('#txtCV_Name').val();

        _row.active = ($("#ckstatus").is(':checked') ? 1 : 0);

        msg="";

        if(_row.CV_Code=="")
            msg+="<br>+ Chưa nhập mã.";
        if(_row.CV_Name=="")
            msg+="<br>+ Chưa nhập tên.";



        if (bAddEdit)
        {
            //if (_row.pwd == '') msg += '\n- Cần vào Mật khẩu;';
            //if (_row.pwd1 == '') msg += '\n- Cần vào Mật khẩu xác nhận;';
        }

        if (msg != '') {
            meAlert('Thông báo','Chưa nhập đầy đủ thông tin',500);
            return false;
        }

        return true;
    }
    //------------- end valid a record
    function _getGroupName(obj)
    {
        var s = '';
        for (i = 0; i < obj.length; i++)
        {
            s += '<span class="groupname" >' + obj[i] + '</span>';
        }
        return s;
    }

    function _showGrid_old() {

        var crudServiceBaseUrl = controllerURL ;

        $("#grid_noidung").kendoGrid({
            dataSource: {
                transport: {
                    read: {
                        url: crudServiceBaseUrl + "/GetList/" + "@ViewBag.mn_tt",
                        dataType: "json"
                    }
                },

                //data: data,
                schema: {
                    parse : function(data) {
                                return data.data;
                        }
                },
                pageSize: @ViewBag.pagesize
            },
            filterable: {
               // mode:"row",
                extra: false,
                operators: {
                    string: {
                        contains: "Contains...",
                        startswith: "Starts with",
                        eq: "Is equal to"
                        //, neq: "Is not equal to"
                    }
                }
            },

            // height: 500,
            //toolbar: ["excel"],
            scrollable: false,
            sortable: { mode: "multiple", allowUnsort: true },
            pageable: { input: false, numeric: true },
            reorderable: true,
            resizable: true,
            groupable: true,
            allowCopy: true,
            selectable: "multiple cell",
            excel: {
                fileName: exportFileName + ".xlsx",
                allPages: true,
                filterable: true
            },
            pdf: {
                author: "RIC Total",
                creator: "RIC Total",
                date: new Date(),
                fileName: exportFileName + ".pdf",
                subject: "RIC Total: " + exportFileName,
                title: "RIC Total: " + exportFileName,
                margin: { left: "20pt", right: "20pt", top: "15mm", bottom: "15mm" },
                paperSize: "A4",
                landscape: true,
                scale: 0.8,
                avoidLinks: true,
                repeatHeaders: true,
                template: $("#page-template").html(),
                allPages: true
            },

            columns: [
                {field: "id", title: "No.", template: "#= ++recordnumber#", filterable: false   , sortable: false},
                {
                    title: "<input type=checkbox id='ckcheckall' onclick='_checkAll();'>"
                    , template: "<input type=checkbox value='#=id#'>"               , filterable: false , sortable: false
                }, {
                    title: ""
                    , template: "<a href='javascript://' class='bg-green' title='Thông tin chi tiết => Sửa'  style='padding:5px;' onclick=' _editItem(\"#=id#\",\"#= recordnumber #\")'  data-toggle='modal' data-target='\\#dlg@(ViewBag.tblname)'><i class='fa fa-edit'></a>"
                    , filterable: false  , sortable: false
                },

                { field: "doc_code", title: "Mã tài liệu", filterable: { cell: { operator: "contains" } } },
                { field: "doc_title", title: "Tên tài liệu", filterable: { cell: { operator: "contains" } } },


               /* {title: "Nhóm quyền", template: "#= _getGroupName(qten) #",  filterable: false , sortable: false}, */

                { field: "active", title: "Status"}

       ],
            dataBound: function (e) {
                recordnumber = 0;
                for (var i = 0; i < this.columns.length; i++) this.autoFitColumn(i);
            }
        }) ;

         grid = $("#grid_noidung").data("kendoGrid");
    }

        //Hien thi thong tin tren grid kendo
    function _showGrid() {

        $("#grid_noidung").kendoGrid({
            dataSource: {
                transport: {
                    read: {
                        url:  controllerURL + "/GetList/" + js_mn_tt,
                        dataType: "json",
                        method: "POST"
                    }
                },

                schema: {
                    parse: function (data) {
                        data.data = JSON.parse(data.data);
                        return data;
                    },
                    data: function (data) {
                        return data.data
                    },
                    total: function (data) {
                        return data.total; // total is returned in the "total" field of the response
                    },

                    model: {
                        fields: {

                            doc_title: { type: "string" },
                            chunk_title: { type: "string" },
                            //Official_Organization: { type: "string" },
                            //Supervisory_Organization:{type:"string"}

                        }
                    }
                },
                pageSize: @ViewBag.pagesize,
                serverPaging: true,
            },
            filterable: {

            },

            scrollable: false,
            sortable: { mode: "multiple", allowUnsort: true },
            pageable: true,
            reorderable: true,
            resizable: true,
            columns: [
                { field: "id", title: "No.", template: "#= ++recordnumber#", filterable: false, sortable: false },
                {
                    title: "<input type=checkbox id='ckcheckall' onclick='_checkAll();'>"
                    , template: "<input type=checkbox value='#=id#'>"               , filterable: false , sortable: false
                }, {
                    title: ""
                    , template: "<a href='javascript://' class='bg-green' title='Thông tin chi tiết => Sửa'  style='padding:5px;' onclick=' _editItem(\"#=id#\",\"#= recordnumber #\")'  data-toggle='modal' data-target='\\#dlg@(ViewBag.tblname)'><i class='fa fa-edit'></a>"
                    , filterable: false  , sortable: false
                },
                { field: "doc_title", title: "Tài liệu", filterable: { cell: { operator: "contains" } } },
                { field: "chunk_title", title: "Chunk Title", filterable: { cell: { operator: "contains" } } },
               // { field: "User_FullName", title: "Tác giả", filterable: { cell: { operator: "contains" } } },
               // { field: "Official_Organization", title: "Official Organization", filterable: { cell: { operator: "contains" } } },
               // { field: "Supervisory_Organization", title: "Supervisory Organization", filterable: { cell: { operator: "contains" } } },


            ],
            dataBound: function (e) {
                recordnumber = 0;
                for (var i = 0; i < this.columns.length; i++) this.autoFitColumn(i);
            }
        });
        grid = $("#grid_noidung").data("kendoGrid");
    }
//---------------------------------


    function _gridUpdateItem() {

        var grid = $("#grid_noidung").data("kendoGrid");
        var dataSource = grid.dataSource;
        var dataItem = grid.dataItem("tbody tr:eq(" + _EDIT_INDEX + ")"); //get data
        dataItem["category_code"] = _row.category_code;
        dataItem["CV_Name"] = _row.CV_Name;

        dataItem["active"] = _row.active;

       // dataItem["active"] = _row.active;

        grid.refresh();
    }
    //-------------end edit a record


</script>